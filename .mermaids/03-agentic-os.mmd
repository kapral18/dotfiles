%% ============================================================================
%% 03-agentic-os.mmd — Agentic OS: governance + context + execution layers.
%% Entry SOPs + MCP/model registries + per-tool config generation.
%% Skills/hooks file-level detail → 03b. Per-tool config files → 12.
%% ============================================================================
flowchart TB
    classDef gov fill:#3a1b2b,stroke:#f48fb1,color:#fce4ec,stroke-width:2px;
    classDef ctx fill:#1b3a2b,stroke:#81c784,color:#e8f5e9;
    classDef exec fill:#3a2b1b,stroke:#ffb74d,color:#fff3e0;
    classDef data fill:#1d3b53,stroke:#7fb3d5,color:#eaf2f8;

    subgraph GOV["1 · Governance (entrypoints, chezmoi-managed)"]
        AG["readonly_AGENTS.md → ~/AGENTS.md (Cursor+OpenCode primary)"]:::gov
        CL["readonly_CLAUDE.md → ~/CLAUDE.md (full SOP §1-§7)"]:::gov
        GM["dot_gemini/readonly_GEMINI.md → ~/.gemini/GEMINI.md"]:::gov
        SK["home/exact_dot_agents/exact_skills/ → ~/.agents/skills/<br/>42 skills, intent-routed (see 03b)"]:::gov
        AG -->|Use when… load| SK
        CL --> SK
    end

    subgraph CTX["2 · Context (single sources of truth)"]
        REG[[".chezmoidata/mcp_servers.yaml<br/>generic registry; current work/domain servers:<br/>scsi-main(http sso) · scsi-local (ES stdio) · slack(http oauth)"]]:::data
        MODELS[[".chezmoidata/ai_models.yaml (litellm catalog)<br/>reasoning · thinkingBudgets · contextWindow · cost<br/>+ agent_review_models (review-lane registry: per-harness lanes/verifier → profile frontmatter)"]]:::data
        GEN["scripts/: mcp_registry.py · generate_mcp_configs.py<br/>resolve $(pass …) · filter by tool + work_only/isWork"]:::ctx
        REG --> GEN
    end

    subgraph EXECL["3 · Execution (per-tool, .work/.personal merged at apply)"]
        CURSOR["Cursor (primary): dot_cursor/hooks.json + filtered MCP<br/>exact_agents/ review controller+PR gate+workers → ~/.cursor/agents/"]:::exec
        CLAUDE["Claude Code: dot_claude/settings.{work,personal,llama-cpp}.json"]:::exec
        GEMINI["Gemini CLI: dot_gemini/settings.json + exact_commands/"]:::exec
        OPENCODE["OpenCode: dot_config/opencode/*.jsonc (LiteLLM aliases)"]:::exec
        CODEX["Codex: dot_codex/private_config.{work,personal}.toml<br/>+ ,codex bearer-token env wrapper for hosted MCP"]:::exec
        PI["Pi: dot_pi/agent/* (Gemini 3.1 Pro default)"]:::exec
        COPILOT["Copilot CLI: private_dot_copilot/* (settings + gates + review agents;<br/>MCP stdio-only, OAuth http unusable)"]:::exec
        TUICR["tuicr: dot_config/tuicr/readonly_config.toml"]:::exec
        LOCAL["llama.cpp (local, opt-in)"]:::exec
    end

    GEN -->|07-generate-mcp-configs + 07-merge-* hooks| EXECL
    MODELS -->|generate_pi_models / merge_opencode_models| EXECL
    SK -. symlinked into .-> CURSOR & CLAUDE & OPENCODE & CODEX & COPILOT

    subgraph HOOKS["Cursor lifecycle hooks (dot_cursor/hooks.json) — detail in 03b"]
        H["sessionStart→session_context · after*→worklog_recorder<br/>beforeShell→gemini-*-gate (failClosed)"]:::ctx
    end
    GOV -.enforced at runtime by.-> HOOKS
    MEM[("/tmp/specs/<pwd>/<topic>.* (ephemeral memory, ,agent-memory)")]:::data
    HOOKS <--> MEM
    KBDB[("~/.local/share/ai-kb/ (durable memory, ,ai-kb)<br/>shared: Ralph + cursor-cli + pi via ai-kb skill")]:::data
    SK <--> KBDB
