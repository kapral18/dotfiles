%% ============================================================================
%% S1-flow-apply-reconcile.mmd ÔÇö FLOW: how a `chezmoi apply` actually converges.
%% Traces INPUT (source + data + init bool) Ôćĺ TRANSFORM (template + ordered hooks)
%% Ôćĺ OUTPUT ($HOME targets) Ôćĺ RUNTIME (what consumes them). Files are nodes ON the
%% flow, not a tree. Realizes concepts C1, C2, C3, C4, C5, C6. (drill: 01,02)
%% ============================================================================
flowchart LR
    classDef in fill:#1d3b53,stroke:#7fb3d5,color:#eaf2f8;
    classDef xf fill:#3a2f15,stroke:#e0b341,color:#fff8e1;
    classDef out fill:#1b3a2b,stroke:#81c784,color:#e8f5e9;
    classDef run fill:#3a1b2b,stroke:#f48fb1,color:#fce4ec;
    classDef gate fill:#4a1f1f,stroke:#ef9a9a,color:#ffebee;

    subgraph INPUT["INPUT ┬Ě sources of truth (C1/C2)"]
        SRC["home/** source tree<br/>(name-prefixes encode mode/perms)"]:::in
        DATA[".chezmoidata/*.yaml<br/>mcp_servers ┬Ě ai_models ┬Ě packages"]:::in
        INIT[".chezmoi.toml.tmpl prompt<br/>Ôçĺ .isWork, email, keys (C3)"]:::in
    end

    subgraph XFORM["TRANSFORM ┬Ě template + ordered lifecycle (C4)"]
        TMPL["text/template render<br/>{{ if .isWork }} branches"]:::xf
        B["run_once_BEFORE_*<br/>bootstrap: brew, mise, dirs"]:::xf
        OC["run_onchange_AFTER_*<br/>HASH-GATED: complete direct/transitive local transform closure"]:::gate
        LIB["scripts/chezmoi_lib.sh + typed scripts/*.py (C6)<br/>pick_src(isWork) ┬Ě ownership reconcile ┬Ě checksum + artifact ledger lifecycle"]:::xf
        ONCE["run_once_AFTER_*<br/>one-shot: macOS defaults, app icons"]:::xf
    end

    subgraph OUTPUT["OUTPUT ┬Ě $HOME build artifacts (C1)"]
        TGT["rendered dotfiles in $HOME<br/>~/.config/**, ~/.ssh/*.pub, rc files"]:::out
        GEN["GENERATED per-tool configs<br/>source-owned policy + explicit runtime buckets"]:::out
        MAN["managed_configs.tsv<br/>(generic literal checksum drift, C4)"]:::out
        ART["generated_artifacts.v1.json<br/>(AI sourceÔćĺtransformÔćĺowned targetÔćĺconsumer trace)"]:::out
    end

    subgraph RUNTIME["RUNTIME ┬Ě who consumes the build"]
        SH["shell/editor/tmux read rc + configs"]:::run
        AG["AI tools read GENERATED configs + SOPs (C7)"]:::run
        CP[",copilot launch-time reconcile:<br/>locked header-auth batch from canonical registry Ôćĺ<br/>semantic config write + conditional artifact row"]:::run
        PKG["declared packages installed/cleaned<br/>(brew bundle --cleanup = list is authoritative)"]:::run
    end

    SRC --> TMPL
    DATA --> TMPL
    INIT --> TMPL
    TMPL --> B --> OC
    OC -->|hash changed| LIB
    OC -->|hash same| SKIP["skip (no-op convergence)"]:::out
    LIB --> ONCE
    LIB -->|"$(pass ÔÇŽ) / 1Password (C5)"| SECRET["secrets resolved at runtime, never written"]:::run
    LIB --> TGT
    LIB --> GEN
    LIB --> MAN
    LIB --> ART
    ONCE --> TGT
    DATA -->|"fan-out (C2)"| GEN
    INIT -->|"isWork picks pair (C3)"| GEN

    TGT --> SH
    GEN --> AG
    ART --> DOC[",doctor ai static report<br/>--live deduped local probes"]:::run
    DATA --> CP
    CP --> GEN
    CP --> ART
    CP --> AG
    DATA --> PKG

    NOTE["MUTATION RULE: change INPUT, never OUTPUT.<br/>Touching a GENERATED node directly = drift erased next apply."]:::gate
