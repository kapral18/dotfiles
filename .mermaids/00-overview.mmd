%% ============================================================================
%% 00-overview.mmd — Master navigation map for kapral18/dotfiles
%% TWO LAYERS:
%%   SEMANTIC CLOUD (read first) — how the system THINKS: concepts+invariants
%%     (S0), cross-cutting flows (S1/S2/S3), and a reverse index (SR) that maps
%%     any file to its concept, blast radius, and co-edit set.
%%   CATALOG (drill-down) — how the system is LAID OUT: 00-13 enumerate every
%%     one of the 1039 tracked files by exact chezmoi source path.
%% `home/` is chezmoi source deployed to $HOME; scripts/tools/website/docs are
%% repo-side (NOT deployed). Each node → a deeper .mmd.
%% ============================================================================
graph TD
    classDef entry fill:#1d3b53,stroke:#7fb3d5,color:#eaf2f8,stroke-width:2px;
    classDef sys fill:#2c2c34,stroke:#b39ddb,color:#f3e5f5;
    classDef ai fill:#3a2b1b,stroke:#ffb74d,color:#fff3e0;
    classDef repo fill:#1b3a2b,stroke:#81c784,color:#e8f5e9;
    classDef data fill:#3a1b2b,stroke:#f48fb1,color:#fce4ec;
    classDef sem fill:#3a1b2b,stroke:#f48fb1,color:#fce4ec,stroke-width:2px;

    ROOT["dotfiles repo (chezmoi source)<br/>~/.local/share/chezmoi · .chezmoiroot=home"]:::entry

    %% ---- SEMANTIC LAYER (read before the catalog) --------------------------
    ROOT ==> SEMHEAD["★ SEMANTIC CLOUD — read first<br/>how it works together, not where files live"]:::sem
    SEMHEAD --> S0["S0 · Concepts & invariants (C1–C13)<br/>S0-concepts.mmd — the 12 ideas the repo is built on"]:::sem
    SEMHEAD --> S1["S1 · Flow: apply → idempotent reconcile<br/>S1-flow-apply-reconcile.mmd"]:::sem
    SEMHEAD --> S2["S2 · Flow: governed agent turn<br/>S2-flow-agent-runtime.mmd"]:::sem
    SEMHEAD --> S3["S3 · Flow: picker SWR + handoff bus<br/>S3-flow-pickers-handoff.mmd"]:::sem
    SEMHEAD --> SR["SR · Reverse index: file → concept →<br/>breaks-if → co-edit set · SR-index.mmd"]:::sem
    SR -. "each row points into" .-> CATHEAD
    S0 -. "instances enumerated in" .-> CATHEAD

    %% ---- CATALOG LAYER (exhaustive per-file drill-down) --------------------
    ROOT ==> CATHEAD["CATALOG — exhaustive per-file drill-down (00–13)"]:::entry

    CATHEAD --> CZ["01 · Chezmoi apply pipeline<br/>01-chezmoi-pipeline.mmd"]:::sys
    CATHEAD --> PKG["02 · Package management ladder<br/>02-package-management.mmd"]:::sys
    CATHEAD --> AIOS["03 · Agentic OS (SOP+MCP+models)<br/>03-agentic-os.mmd"]:::ai
    CATHEAD --> SKILLS["03b · Skills + hooks (every file)<br/>03b-agent-skills-hooks.mmd"]:::ai
    CATHEAD --> RALPH["04 · Ralph state machine<br/>04-ralph-state-machine.mmd"]:::ai
    CATHEAD --> RALPHCP["04b · Ralph control plane + TUI<br/>04b-ralph-control-plane.mmd"]:::ai
    CATHEAD --> TMUX["05 · Tmux config + pickers (every file)<br/>05-tmux-pickers.mmd"]:::sys
    CATHEAD --> WT["06 · Worktree / GitHub workflow<br/>06-worktree-workflow.mmd"]:::sys
    CATHEAD --> SEM["07 · Shell + terminals + macOS<br/>07-shell-editor-macos.mmd"]:::sys
    CATHEAD --> NVIM["07b · Neovim (every lua file)<br/>07b-neovim.mmd"]:::sys
    CATHEAD --> BIN["07c · ~/bin commands (every script)<br/>07c-bin-commands.mmd"]:::sys
    CATHEAD --> SEC["08 · Security / identity / dotfiles<br/>08-security-and-dotfiles.mmd"]:::data
    CATHEAD --> VAL["09 · Repo dev/validation loop<br/>09-repo-validation.mmd"]:::repo
    CATHEAD --> DOCS["10 · Docs site + repo meta<br/>10-docs-and-repo-meta.mmd"]:::repo
    CATHEAD --> SCRIPTS["11 · scripts/ helpers (every file)<br/>11-scripts-helpers.mmd"]:::repo
    CATHEAD --> AICFG["12 · AI tool configs (every file)<br/>12-ai-tool-configs.mmd"]:::ai
    CATHEAD --> APPS["13 · App configs (every file)<br/>13-app-configs.mmd"]:::sys

    subgraph KEY["chezmoi naming key (attributes encoded in source filenames)"]
        K1["exact_=managed dir · dot_=leading '.' · readonly_=r--r--r--<br/>executable_=+x · private_=0600 · empty_=keep-if-empty<br/>symlink_=symlink · .tmpl=Go-template · .chezmoiignore=skip"]:::data
    end

    subgraph COUNTS["file census (1039 total)"]
        C1["nvim 140 · tmux 119 · Alfred 115 (86 png) · bin 76<br/>docs 73 · agents 63 + runtime profiles 37 · ralph-tui 33 · chezmoiscripts 30<br/>scripts 43 · fish 57 · website 14 · home-root 33 · rest"]:::repo
    end
