%% ============================================================================
%% S2-flow-agent-runtime.mmd — FLOW: Palantir legion runtime.
%% Traces one effort from summon through staged agent panes, deterministic
%% supervisor transitions, adversarial review, verify, human-ready handoff, and
%% memory routing. Realizes C7, C8, C11, C12, C13. (drill: 03, 03b, 04, 12)
%% ============================================================================
flowchart TB
    classDef in fill:#1d3b53,stroke:#7fb3d5,color:#eaf2f8;
    classDef gov fill:#3a2f15,stroke:#e0b341,color:#fff8e1;
    classDef loop fill:#1b3a2b,stroke:#81c784,color:#e8f5e9;
    classDef gate fill:#4a1f1f,stroke:#ef9a9a,color:#ffebee;
    classDef mem fill:#3a1b2b,stroke:#f48fb1,color:#fce4ec;

    START([",palantir summon <goal>"]):::in
    START --> SPEC["resolve worktree + goal packet<br/>create ~/.local/state/palantir/legions/<id>/manifest.json"]:::mem
    SPEC --> TMUX["create tmux session for the legion<br/>window 0 command: coordinator pane + deterministic supervisor pane<br/>one window per stage"]:::loop
    TMUX --> CFG["load ~/.config/palantir/config.toml<br/>role panes may be copilot / claude / pi / opencode"]:::gov
    CFG --> GOV["load SOP + palantir skill<br/>generic gates stay in SOP; stage roles receive bounded task prompts"]:::gov

    GOV --> SUP["supervisor.py loop<br/>read manifest + machine.py transition tables<br/>durably drain pending_actions + pending_wakes<br/>read stages/<stage>.result.json handshakes"]:::loop
    SUP --> COMPOSER{"composer.py pane classifier"}:::gate
    COMPOSER -->|empty| INJECT["send the next safe word into the owning pane"]:::loop
    COMPOSER -->|pending / busy / unknown| WAIT["wait + retry; do not interleave input or advance stage"]:::gate
    WAIT --> SUP
    INJECT --> SNAP["record stage baseline paths<br/>start role; record completion delta"]:::mem
    SNAP --> STAGE

    STAGE["stage path:<br/>summon → triage → optional diagnose/investigate → implement<br/>→ adversarial_review → verify"]:::loop
    STAGE --> HANDSHAKE["role pane writes stages/<stage>.result.json<br/>schema carries status, blockers, family, checks, next hint"]:::mem
    HANDSHAKE --> REVIEW{"adversarial_review guard"}:::gate
    REVIEW -->|implement family == review family| HOLD
    REVIEW -->|blockers > 0 and budget remains| RETURNS["bounded return to implement<br/>queued wakes survive blocked panes; identical unresolved word dedupes"]:::loop
    RETURNS --> SUP
    REVIEW -->|blockers = 0| VERIFY

    VERIFY["machine-run verify criteria checks<br/>exit 0 = green"]:::loop
    VERIFY -->|green + blockers=0| READY["cleared_for_human"]:::gate
    VERIFY -->|failed + budget remains| RETURNS
    VERIFY -->|failed + budget exhausted| HOLD

    READY --> PROOF["evidence packet is path/cmd/probe anchored<br/>claims without anchors stay Unknown"]:::gate
    PROOF --> DASH["dashboard.py popup via tmux prefix+A<br/>socket-aware attach; stage age + transport/queue health<br/>typed close confirmation; statusline P/H/C + orphan O + corrupt E"]:::loop
    DASH --> CLOSE["human operator grants or banishes legion<br/>PALANTIR_AGENT_ROLE callers are refused<br/>grant preflights teardown"]:::in
    CLOSE --> MEMORY["persist memory-routing.json before teardown:<br/>,ai-kb for verified durable learnings<br/>/tmp/specs for effort spec/worklog<br/>repo AGENTS.md for repo-intrinsic conventions"]:::mem
    MEMORY --> TEARDOWN["stop supervisor + kill legion session<br/>remove only an owned clean worktree<br/>record teardown status"]:::loop
    TEARDOWN --> DONE(["done"])

    HOLD --> DASH
    HOLD -->|operator instruction| SUP
    HOLD -->|banish| CLOSE
