%% ============================================================================
%% S2-flow-agent-runtime.mmd — FLOW: one agent turn as a governed pipeline.
%% Traces a prompt from session start → governance load → verify loop → gated
%% side effects → memory. Realizes C7, C8, C13 (and C11/C12 when work is Ralph).
%% Files are nodes ON the control flow. (drill: 03, 03b, 04, 04b, 12)
%% ============================================================================
flowchart TB
    classDef in fill:#1d3b53,stroke:#7fb3d5,color:#eaf2f8;
    classDef gov fill:#3a2f15,stroke:#e0b341,color:#fff8e1;
    classDef loop fill:#1b3a2b,stroke:#81c784,color:#e8f5e9;
    classDef gate fill:#4a1f1f,stroke:#ef9a9a,color:#ffebee;
    classDef mem fill:#3a1b2b,stroke:#f48fb1,color:#fce4ec;

    AILAUNCH[",ai optional unified entry:<br/>generated consumer_view.v1 validates complete available catalogs;<br/>resolve aliases + depth/execution/connectivity → redacted InvocationPlan;<br/>unsupported explicit hard constraints stop before leaf launch"]:::gov
    START(["session start"]):::in
    AILAUNCH -. "exec selected leaf" .-> START
    START --> SS["sessionStart hook → session_context.py<br/>native session ID resolves one topic binding;<br/>inject verification/proof prefix.txt +<br/>topic bucket index OR bounded /tmp/specs spec+worklog;<br/>warm-start IDs persist by canonical session key (C13)"]:::mem
    SS -. "balanced/deep adapters only" .-> RESIDENT["resident FastEmbed ensure (fail-open):<br/>Claude · Gemini · OpenCode · Copilot · Pi;<br/>fast skips warm-up · generation-private socket · 300s idle;<br/>Cursor/Codex do not warm"]:::mem
    SS --> PRTURN{"runtime has automatic<br/>per-turn context injection?"}:::mem
    PRTURN -->|Claude/Gemini/OpenCode/Copilot/Pi| HOTRECALL["AI_AGENT_DEPTH recall:<br/>fast=off · balanced=fetch6/inject3 · deep=fetch12/inject5;<br/>same relevance/scope/dedupe gates · query stdin only;<br/>AI_EMBED_CONNECT_ONLY=1 · never spawn/restart"]:::mem
    PRTURN -->|Cursor/Codex/other| SOP
    HOTRECALL --> SOP
    HOTRECALL -. "uses" .-> RESIDENT
    SOP["load SOP entrypoints<br/>~/AGENTS.md · CLAUDE.md · GEMINI.md (C7)"]:::gov
    SOP --> SKILL{"intent matches a skill<br/>'Use when' clause?"}:::gov
    SKILL -->|yes| LOAD["read skill SKILL.md → follow as binding procedure"]:::gov
    SKILL -->|no| WORK
    LOAD --> DOMAIN{"verified repo/org/product<br/>domain overlay applies?"}:::gov
    DOMAIN -->|yes| DLOAD["load overlay for domain additions only<br/>generic mechanics stay in primary skill"]:::gov
    DOMAIN -->|no| RECALL
    DLOAD --> RECALL
    RECALL["ai-kb skill (when relevant): ,ai-kb search<br/>recall durable capsules before work (C13)"]:::mem
    RECALL --> WORK
    WORK["do work: investigate-first, external-truth,<br/>verify don't guess (C7)"]:::loop
    TT["text-tournament (eligible material prose only):<br/>interactive → 3 candidates + cross-family two-order winner;<br/>Ralph executor → candidates + TOURNAMENT; existing reviewer/re-reviewer evaluate"]:::loop
    WORK -. "material prose with real alternatives" .-> TT
    TT -. "informs next edit" .-> WORK
    PROOF["proof skill + ,proof ledger only after hard triggers:<br/>criteria → evidence → review notes → check/report (C8/C13)"]:::loop

    WORK --> PHARD{"hard-triggered freeform proof<br/>needed?"}:::loop
    PHARD -->|yes| PROOF
    PHARD -->|no| CLAIM{"emit factual/runtime claim?"}:::loop
    PROOF --> CLAIM
    CLAIM -->|yes| ANCHOR{"claim carries hard anchor<br/>(path/cmd/probe) or 'Unknown because…'? (C8)"}:::gate
    ANCHOR -->|no| RETRY["SOP External Truth (C8): verify from<br/>file/cmd/probe or demote to 'Unknown', then continue"]:::gate
    RETRY --> WORK
    ANCHOR -->|yes| SIDE
    CLAIM -->|no| SIDE

    SIDE{"human-visible side effect?<br/>(PR/issue/Slack/email)"}:::gate
    SIDE -->|"human target"| HGATE["Human-Visible Publication Gate:<br/>draft + show payload + WAIT for approval (C7)"]:::gate
    SIDE -->|"verified bot thread"| AUTO["auto-reply/resolve (carve-out)"]:::loop
    SIDE -->|none| DONE
    HGATE -->|approved| EMIT["gh/gws/slack side effect"]:::loop
    AUTO --> EMIT
    EMIT --> DONE

    DONE(["turn complete"]):::loop
    DONE --> PERSIST["postTool → worklog_dispatcher.sh returns early;<br/>fsynced session queue → bounded transient flush → bound worklog;<br/>startup/harvest expose pending errors (C13)<br/>+ agent-driven ,ai-kb remember for verified durable insights"]:::mem

    subgraph RALPH["if work == Ralph orchestration (C11/C12)"]
        direction LR
        RR["roles.json + family_of() gate:<br/>reviewer ≠ re_reviewer family (C11)"]:::gate
        SM["manifest phase advances; crash→park;<br/>supervisor/resume relaunch (C12);<br/>reviewer BLOCK verdict → needs_human park,<br/>cleared ONLY by ,ralph resume"]:::loop
        XPORT["subprocess prompt transport:<br/>prompt.md is the source; cursor gets it as the<br/>trailing positional arg ($(cat prompt.md));<br/>pi/command read it via '< prompt.md';<br/>subprocess stdin is EMPTY (never double-supplied)"]:::gate
        RTT["executor prompt → text-tournament Ralph lane:<br/>3 candidates + TOURNAMENT; no nested evaluator;<br/>reviewer/re-reviewer evaluate the selected artifact"]:::loop
        RR --> SM
        SM --> XPORT
        XPORT -. "executor only, eligible prose" .-> RTT
    end
    WORK -. "ralph go" .-> RALPH
    SM -. "anchored like any agent" .-> ANCHOR
