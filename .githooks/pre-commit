#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "$repo_root" ]; then
  exit 0
fi

cd "$repo_root"

staged_paths="$(
  git diff --cached --name-only --diff-filter=ACMR
)"

if [ -z "$staged_paths" ]; then
  exit 0
fi

# Convert string of paths to an array, handling spaces correctly
mapfile -t paths < <(echo "$staged_paths")

# Avoid breaking partial-staging: formatting rewrites the working tree file and
# then stages it. If a file has unstaged changes, abort and let the user decide.
for path in "${paths[@]}"; do
  if [ -n "$(git diff --name-only -- "$path")" ]; then
    echo "pre-commit: refusing to auto-format with unstaged changes in: $path" >&2
    echo "pre-commit: stage the whole file (or stash changes) then retry." >&2
    exit 1
  fi
done

# Run lint + test; on lint failure, auto-format, re-stage, and re-check.
if ! make -s check 2>/dev/null; then
  make -s fmt
  git add -- "${paths[@]}"
  make -s check
fi
