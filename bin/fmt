#!/usr/bin/env bash
if [ "${BASH_VERSINFO[0]:-0}" -lt 4 ]; then
  _b="$(brew --prefix bash 2>/dev/null)/bin/bash"
  [ -x "$_b" ] && exec "$_b" "$0" "$@"
  printf 'error: bash 4+ required (mapfile)\n' >&2
  exit 1
fi
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

usage() {
  cat <<'EOF'
Usage: bin/fmt [--check] [--type TYPE] [FILES...]

Format source files in this dotfiles repo.

Options:
  --check       Check formatting without writing (exit 1 if unformatted)
  --type TYPE   Only run one formatter: md, json, yaml, sh, lua, fish, py, go
  (no args)     Format all tracked files plus untracked, non-ignored files

Formatters:
  md               ,unwrap-md + markdownlint --fix + prettier
  json, yaml       prettier
  sh               shfmt (2-space, bash)
  lua              stylua
  fish             fish_indent
  py               ruff format
  go               goimports + gofumpt (fallback: gofmt)
EOF
  exit 0
}

check_mode=false
type_filter=""
files=()

while [[ $# -gt 0 ]]; do
  case "$1" in
  --check)
    check_mode=true
    shift
    ;;
  --type)
    type_filter="$2"
    shift 2
    ;;
  --help | -h) usage ;;
  *)
    files+=("$1")
    shift
    ;;
  esac
done

need_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    printf 'missing: %s (install via: brew install %s)\n' "$1" "${2:-$1}" >&2
    return 1
  fi
}

ok=true

IGNORE_PATTERNS=(
  "home/Alfred.alfredpreferences/"
)

is_ignored() {
  local f="$1"
  for pat in "${IGNORE_PATTERNS[@]}"; do
    [[ "$f" == "$pat"* ]] && return 0
  done
  return 1
}

is_sh_file() {
  local f="$1"
  [[ "$f" == *.sh || "$f" == *.sh.tmpl || "$f" == *.bash || "$f" == *.ksh ]] && return 0
  [[ ! -f "$f" ]] && return 1
  local head
  head="$(head -n 1 "$f" 2>/dev/null || true)"
  [[ "$head" == '#!/usr/bin/env bash'* || "$head" == '#!/usr/bin/env sh'* || "$head" == '#!'*'/bash'* || "$head" == '#!'*'/sh'* ]] && return 0
  return 1
}

is_py_file() {
  local f="$1"
  [[ "$f" == *.py ]] && return 0
  [[ ! -f "$f" ]] && return 1
  local head
  head="$(head -n 1 "$f" 2>/dev/null || true)"
  [[ "$head" == '#!/usr/bin/env python'* || "$head" == '#!'*'/python'* ]] && return 0
  return 1
}

is_md_file() {
  # chezmoi symlink_ sources hold a target path, not markdown
  case "${1##*/}" in
  symlink_*) return 1 ;;
  esac
  [[ "$1" == *.md ]]
}
is_json_file() { [[ "$1" == *.json || "$1" == *.jsonc ]]; }
is_yaml_file() { [[ "$1" == *.yaml || "$1" == *.yml ]]; }
is_lua_file() { [[ "$1" == *.lua ]]; }
is_fish_file() { [[ "$1" == *.fish ]]; }
is_go_file() { [[ "$1" == *.go ]]; }

collect_by_func() {
  local func="$1"
  if [[ ${#files[@]} -gt 0 ]]; then
    for f in "${files[@]}"; do
      if "$func" "$f"; then
        is_ignored "$f" || echo "$f"
      fi
    done
  else
    while IFS= read -r f; do
      [[ -e "$f" ]] || continue
      if "$func" "$f"; then
        is_ignored "$f" || echo "$f"
      fi
    done < <(git ls-files --cached --others --exclude-standard 2>/dev/null || true)
  fi
}

should_run() {
  [[ -z "$type_filter" || "$type_filter" == "$1" ]]
}

# --- formatter groups ---
# Each group is a self-contained function that prints its own progress, mutates
# files (or checks them), and returns non-zero on failure. Groups operate on
# disjoint file sets, so they are launched concurrently (see runner below). The
# only ordering constraint lives *inside* the md group: ,unwrap-md -> markdownlint
# -> prettier all touch the same markdown files and must stay sequential.

# md group: ,unwrap-md -> markdownlint --fix -> prettier (md + json + yaml).
# json/yaml have no ordering dependency, but bundling them into prettier keeps it
# a single bulk invocation (the original behavior) and they ride along harmlessly.
fmt_md() {
  local rc=0
  if should_run md; then
    if ! command -v ,unwrap-md >/dev/null 2>&1; then
      printf 'missing: ,unwrap-md (install via chezmoi: chezmoi apply %s)\n' "$HOME/bin/,unwrap-md" >&2
      return 1
    fi
    mapfile -t md_files < <(collect_by_func is_md_file | sort -u)
    if [[ ${#md_files[@]} -gt 0 ]]; then
      if $check_mode; then
        printf ',unwrap-md: checking %d files\n' "${#md_files[@]}"
        ,unwrap-md --check "${md_files[@]}" || rc=1
      else
        printf ',unwrap-md: unwrapping %d files\n' "${#md_files[@]}"
        ,unwrap-md "${md_files[@]}"
      fi
    fi

    need_cmd markdownlint || return 1
    if [[ ! -f "$HOME/.markdownlint.jsonc" ]]; then
      printf 'missing: %s (apply dotfiles to install it)\n' "$HOME/.markdownlint.jsonc" >&2
      return 1
    fi
    if [[ ${#md_files[@]} -gt 0 ]]; then
      if $check_mode; then
        printf 'markdownlint: checking %d files\n' "${#md_files[@]}"
        if ! markdownlint -c "$HOME/.markdownlint.jsonc" -- "${md_files[@]}" >/dev/null 2>&1; then
          rc=1
          markdownlint -c "$HOME/.markdownlint.jsonc" -- "${md_files[@]}" 2>&1 | sed 's/^/  /' || true
        fi
      else
        printf 'markdownlint: fixing %d files\n' "${#md_files[@]}"
        markdownlint --fix -c "$HOME/.markdownlint.jsonc" -- "${md_files[@]}" 2>/dev/null || true
      fi
    fi
  fi

  if should_run md || should_run json || should_run yaml; then
    need_cmd prettier || return 1
    mapfile -t prettier_files < <(
      {
        should_run md && collect_by_func is_md_file
        should_run json && collect_by_func is_json_file
        should_run yaml && collect_by_func is_yaml_file
      } | sort -u
    )
    if [[ ${#prettier_files[@]} -gt 0 ]]; then
      if $check_mode; then
        printf 'prettier: checking %d files\n' "${#prettier_files[@]}"
        prettier --check "${prettier_files[@]}" 2>/dev/null || rc=1
      else
        printf 'prettier: formatting %d files\n' "${#prettier_files[@]}"
        prettier --write "${prettier_files[@]}" >/dev/null 2>&1
      fi
    fi
  fi
  return $rc
}

# shfmt: shell scripts (bulk invocation)
fmt_sh() {
  should_run sh || return 0
  local rc=0
  need_cmd shfmt || return 1
  mapfile -t sh_files < <(collect_by_func is_sh_file | sort -u)
  [[ ${#sh_files[@]} -gt 0 ]] || return 0
  if $check_mode; then
    printf 'shfmt: checking %d files\n' "${#sh_files[@]}"
    if ! shfmt -d "${sh_files[@]}" >/dev/null 2>&1; then
      rc=1
      shfmt -l "${sh_files[@]}" 2>/dev/null | sed 's/^/  unformatted: /'
    fi
  else
    printf 'shfmt: formatting %d files\n' "${#sh_files[@]}"
    shfmt -w "${sh_files[@]}"
  fi
  return $rc
}

# stylua: lua (bulk invocation)
fmt_lua() {
  should_run lua || return 0
  local rc=0
  need_cmd stylua || return 1
  mapfile -t lua_files < <(collect_by_func is_lua_file | sort -u)
  [[ ${#lua_files[@]} -gt 0 ]] || return 0
  if $check_mode; then
    printf 'stylua: checking %d files\n' "${#lua_files[@]}"
    if ! stylua --check "${lua_files[@]}" >/dev/null 2>&1; then
      rc=1
      stylua --check "${lua_files[@]}" 2>&1 | grep 'Diff' | sed 's/^.*in /  unformatted: /' || true
    fi
  else
    printf 'stylua: formatting %d files\n' "${#lua_files[@]}"
    stylua "${lua_files[@]}"
  fi
  return $rc
}

# fish_indent: fish (one at a time — fish_indent has no bulk mode)
fmt_fish() {
  should_run fish || return 0
  local rc=0
  need_cmd fish_indent fish || return 1
  mapfile -t fish_files < <(collect_by_func is_fish_file | sort -u)
  [[ ${#fish_files[@]} -gt 0 ]] || return 0
  local fish_bad=0
  if $check_mode; then
    printf 'fish_indent: checking %d files\n' "${#fish_files[@]}"
    for f in "${fish_files[@]}"; do
      [[ -f "$f" ]] || continue
      if ! diff -q <(fish_indent <"$f") "$f" >/dev/null 2>&1; then
        printf '  unformatted: %s\n' "$f"
        ((fish_bad++)) || true
      fi
    done
    [[ $fish_bad -eq 0 ]] || rc=1
  else
    printf 'fish_indent: formatting %d files\n' "${#fish_files[@]}"
    for f in "${fish_files[@]}"; do
      [[ -f "$f" ]] || continue
      fish_indent -w "$f"
    done
  fi
  return $rc
}

# ruff: python (fix + format, matching neovim conform's ruff_fix + ruff_format)
fmt_py() {
  should_run py || return 0
  local rc=0
  need_cmd ruff || return 1
  mapfile -t py_files < <(collect_by_func is_py_file | sort -u)
  [[ ${#py_files[@]} -gt 0 ]] || return 0
  if $check_mode; then
    printf 'ruff: checking %d files\n' "${#py_files[@]}"
    if ! ruff check --select I --diff "${py_files[@]}" >/dev/null 2>&1; then
      rc=1
      printf '  import sorting needed\n'
    fi
    if ! ruff format --check "${py_files[@]}" >/dev/null 2>&1; then
      rc=1
      ruff format --check "${py_files[@]}" 2>&1 | grep 'Would reformat' | sed 's/^/  /' || true
    fi
  else
    printf 'ruff: formatting %d files\n' "${#py_files[@]}"
    ruff check --select I --fix "${py_files[@]}" >/dev/null 2>&1
    ruff format "${py_files[@]}" >/dev/null 2>&1
  fi
  return $rc
}

# go: Go (tools/ralph-tui and any future .go under repo root)
# We deliberately use the same tools that Neovim's conform.nvim uses
# (goimports then gofumpt) so that `bin/fmt --type go` and editor save
# never fight. Falls back to plain gofmt only if the modern pair is absent.
fmt_go() {
  should_run go || return 0
  local rc=0
  local go_files=()
  mapfile -t go_files < <(collect_by_func is_go_file | sort -u)
  [[ ${#go_files[@]} -gt 0 ]] || return 0
  if command -v goimports >/dev/null 2>&1 && command -v gofumpt >/dev/null 2>&1; then
    if $check_mode; then
      printf 'goimports + gofumpt: checking %d files\n' "${#go_files[@]}"
      local unformatted_goimports unformatted_gofumpt unformatted
      unformatted_goimports="$(goimports -l "${go_files[@]}" 2>/dev/null || true)"
      unformatted_gofumpt="$(gofumpt -l "${go_files[@]}" 2>/dev/null || true)"
      unformatted="$(printf '%s\n%s\n' "$unformatted_goimports" "$unformatted_gofumpt" | sort -u | sed '/^$/d')"
      if [[ -n "$unformatted" ]]; then
        rc=1
        printf '%s\n' "$unformatted" | sed 's/^/  unformatted: /'
      fi
    else
      printf 'goimports + gofumpt: formatting %d files\n' "${#go_files[@]}"
      goimports -w "${go_files[@]}"
      gofumpt -w "${go_files[@]}"
    fi
  else
    # Fallback for minimal environments (no goimports/gofumpt in PATH)
    need_cmd gofmt || return 1
    if $check_mode; then
      printf 'gofmt (fallback): checking %d files\n' "${#go_files[@]}"
      local unformatted
      unformatted="$(gofmt -l "${go_files[@]}" 2>/dev/null || true)"
      if [[ -n "$unformatted" ]]; then
        rc=1
        printf '%s\n' "$unformatted" | sed 's/^/  unformatted: /'
      fi
    else
      printf 'gofmt (fallback): formatting %d files\n' "${#go_files[@]}"
      gofmt -w "${go_files[@]}"
    fi
  fi
  return $rc
}

# --- concurrent runner ---
# Launch each independent group in the background, buffering its combined output
# to a temp file. After all finish, flush the buffers in a deterministic order
# so output stays readable, and OR the exit statuses into `ok`.
groups=(md sh lua fish py go)
tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/binfmt.XXXXXX")"
trap 'rm -rf "$tmpdir"' EXIT

pids=()
for g in "${groups[@]}"; do
  "fmt_$g" >"$tmpdir/$g.out" 2>&1 &
  pids+=("$!")
done

for i in "${!groups[@]}"; do
  if ! wait "${pids[$i]}"; then
    ok=false
  fi
  cat "$tmpdir/${groups[$i]}.out"
done

# --- summary ---
if $check_mode; then
  if $ok; then
    printf '\nAll files formatted correctly.\n'
  else
    printf '\nSome files need formatting. Run bin/fmt to fix.\n'
    exit 1
  fi
elif ! $ok; then
  # write mode: a missing tool or other group failure should still fail the run
  exit 1
fi
