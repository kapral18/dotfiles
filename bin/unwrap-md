#!/usr/bin/env python3
"""Unwrap hard-wrapped markdown lines back to one-line-per-logical-unit.

Usage: unwrap-md [--check] FILES...

A continuation line is one that:
- is not blank
- does not start a new structural element (heading, bullet, ordered list,
  blockquote marker, code fence, horizontal rule, HTML tag, table row)
- follows a non-blank line

Continuation lines are joined to the previous line with a single space.

Options:
  --check   Report files that need unwrapping without modifying them (exit 1).
"""
import re
import sys

STRUCTURAL = re.compile(
    r"^("
    r"\s{0,3}#{1,6}\s"
    r"|\s{0,3}[-*+]\s"
    r"|\s{0,3}\d+[.)]\s"
    r"|\s{0,3}>"
    r"|\s{0,3}```"
    r"|\s{0,3}~~~"
    r"|\s{0,3}---"
    r"|\s{0,3}\*\*\*"
    r"|\s{0,3}<[a-zA-Z/]"
    r"|\s{0,3}\|"
    r")"
)


def is_structural(line):
    return bool(STRUCTURAL.match(line))


def is_blank(line):
    return line.strip() == ""


def unwrap(text):
    lines = text.split("\n")
    out = []
    in_code_fence = False
    in_frontmatter = False

    for i, line in enumerate(lines):
        stripped = line.rstrip()

        # YAML frontmatter: starts with --- on line 1, ends at next ---
        if i == 0 and stripped == "---":
            in_frontmatter = True
            out.append(stripped)
            continue
        if in_frontmatter:
            out.append(stripped)
            if stripped == "---":
                in_frontmatter = False
            continue

        if re.match(r"\s{0,3}(`{3,}|~{3,})", stripped):
            in_code_fence = not in_code_fence
            out.append(stripped)
            continue

        if in_code_fence:
            out.append(stripped)
            continue

        if is_blank(stripped):
            out.append("")
            continue

        if is_structural(stripped):
            out.append(stripped)
            continue

        if out and not is_blank(out[-1]):
            out[-1] = out[-1] + " " + stripped.strip()
        else:
            out.append(stripped)

    while len(out) > 1 and out[-1] == "":
        out.pop()
    if text.endswith("\n"):
        out.append("")
    return "\n".join(out)


def main():
    check_mode = "--check" in sys.argv
    paths = [a for a in sys.argv[1:] if a != "--check"]

    if not paths:
        print(__doc__.strip(), file=sys.stderr)
        sys.exit(2)

    dirty = []
    for path in paths:
        with open(path) as f:
            original = f.read()
        result = unwrap(original)
        if result == original:
            continue
        if check_mode:
            dirty.append(path)
        else:
            with open(path, "w") as f:
                f.write(result)
            print(f"unwrapped: {path}")

    if check_mode and dirty:
        for p in dirty:
            print(f"  needs unwrapping: {p}")
        sys.exit(1)


if __name__ == "__main__":
    main()
