{
  "$schema": "https://opencode.ai/config.json",
  "mcp": "__MCP_SERVERS__",
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "{env:LITELLM_API_BASE}",
        "apiKey": "{env:LITELLM_PROXY_KEY}",
      },
      "models": {
        "llm-gateway/model-a": {
          "name": "Model A 🧠 ($5in/$25out)",
          "limit": {
            "context": 100000,
            "output": 8192,
          },
        },
        "llm-gateway/model-b": {
          "name": "Model B ($0.5in/$1.5out)",
          "limit": {
            "context": 50000,
            "output": 8192,
          },
        },
      },
    },
    "azure-foundry": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Azure Foundry",
      "options": {
        "baseURL": "{env:AZURE_FOUNDRY_ENDPOINT}",
        "apiKey": "{env:AZURE_FOUNDRY_API_KEY}",
      },
      "models": {},
    },
  },
}
