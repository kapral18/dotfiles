{
  "providers": {
    "litellm": {
      "baseUrl": "http://localhost:4000/v1",
      "apiKey": "LITELLM_PROXY_KEY",
      "authHeader": true,
      "models": [
        {
          "id": "llm-gateway/model-a",
          "name": "Model A 🧠 ($5in/$25out) (LiteLLM)",
          "api": "openai-completions",
          "contextWindow": 100000,
          "maxTokens": 8192,
          "reasoning": true,
          "thinkingBudgets": {
            "minimal": 1024,
            "high": 32768
          },
          "cost": {
            "input": 5,
            "output": 25,
            "cacheRead": 0,
            "cacheWrite": 0
          }
        },
        {
          "id": "llm-gateway/model-b",
          "name": "Model B ($0.5in/$1.5out) (LiteLLM)",
          "api": "openai-completions",
          "contextWindow": 50000,
          "reasoning": false,
          "cost": {
            "input": 0.5,
            "output": 1.5,
            "cacheRead": 0,
            "cacheWrite": 0
          }
        }
      ]
    },
    "azure-foundry": {
      "baseUrl": "https://test-resource.services.ai.azure.com/openai/v1",
      "apiKey": "AZURE_FOUNDRY_API_KEY",
      "authHeader": true,
      "compat": {
        "supportsDeveloperRole": false
      },
      "models": []
    }
  }
}
