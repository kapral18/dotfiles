{
  "$schema": "https://opencode.ai/config.json",
  "mcp": "__MCP_SERVERS__",
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "{env:LITELLM_API_BASE}",
        "apiKey": "{env:LITELLM_PROXY_KEY}",
      },
      "models": "__LITELLM_MODELS__",
    },
    "azure-foundry": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Azure Foundry",
      "options": {
        "baseURL": "{env:AZURE_FOUNDRY_ENDPOINT}",
        "apiKey": "{env:AZURE_FOUNDRY_API_KEY}",
      },
      "models": "__AZURE_MODELS__",
    },
  },
}
