{
  "alwaysThinkingEnabled": false,
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "model": "fable",
  "effortLevel": "xhigh",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.agents/hooks/session_context.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.agents/hooks/worklog_recorder.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.agents/hooks/worklog_recorder.py",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.agents/hooks/perturn_recall.py",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "voice": {
    "enabled": true,
    "mode": "hold"
  }
}
