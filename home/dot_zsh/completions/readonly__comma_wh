#compdef ,wh

_comma_wh() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Show help]' \
    '1:command:((post\\:"Send staged git patch" get\\:"Receive patch by wormhole code"))' \
    '*::args:->args'

  case "$state" in
    args)
      case "$words[2]" in
        post)
          _arguments
          ;;
        get)
          _message 'wormhole code word'
          ;;
      esac
      ;;
  esac
}

_comma_wh "$@"
