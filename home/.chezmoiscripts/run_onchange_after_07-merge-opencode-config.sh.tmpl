#!/usr/bin/env bash

set -euo pipefail

{{- if eq .isWork true }}
# opencode config desired hash (work): {{ include "dot_config/opencode/readonly_opencode.work.jsonc" | sha256sum }}
# litellm models hash: {{ include ".chezmoidata/litellm_models.yaml" | sha256sum }}
{{- else }}
# opencode config desired hash (non-work): {{ include "dot_config/opencode/readonly_opencode.personal.jsonc" | sha256sum }}
{{- end }}

source_dir="${CHEZMOI_SOURCE_DIR:-{{ .chezmoi.sourceDir }}}"
target="$HOME/.config/opencode/opencode.jsonc"
is_work="{{ if eq .isWork true }}true{{ else }}false{{ end }}"

if [ "$is_work" = "true" ]; then
  src="$source_dir/dot_config/opencode/readonly_opencode.work.jsonc"
  models_yaml="$source_dir/.chezmoidata/litellm_models.yaml"

  desired="$(python3 "$source_dir/../scripts/merge_opencode_models.py" "$src" "$models_yaml")"
else
  src="$source_dir/dot_config/opencode/readonly_opencode.personal.jsonc"
  desired="$(cat "$src")"
fi

mkdir -p "$(dirname "$target")"

if [ -f "$target" ] && [ "$(cat "$target")" = "$desired" ]; then
  exit 0
fi

printf '%s\n' "$desired" >"$target"
