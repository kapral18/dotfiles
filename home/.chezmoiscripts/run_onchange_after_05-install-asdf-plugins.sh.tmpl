#!/usr/bin/env bash

set -euo pipefail

# Track template changes
# {{ include "dot_config/mise/config.toml.tmpl" | sha256sum }}

mise_config_template={{ joinPath .chezmoi.sourceDir "dot_config/mise/config.toml.tmpl" | quote }}

if [[ ! -f "$mise_config_template" ]]; then
  echo "Error: Template not found at $mise_config_template"
  exit 1
fi

if ! command -v mise >/dev/null 2>&1; then
  echo "mise is not installed yet; skipping runtime installation for now."
  exit 0
fi

# Force mise shims ahead of stale asdf shims during transition.
PATH=":${PATH}:"
PATH="${PATH//:$HOME/.asdf/shims:/:}"
PATH="${PATH#:}"
PATH="${PATH%:}"
export PATH="$HOME/.local/share/mise/shims${PATH:+:${PATH}}"

echo "Installing configured runtimes with mise..."
if ! mise install --yes; then
  echo "Error: mise install failed"
  exit 1
fi

echo "Refreshing runtime shims..."
mise reshim || true

echo ""
echo "Current runtimes:"
mise ls --current || true
