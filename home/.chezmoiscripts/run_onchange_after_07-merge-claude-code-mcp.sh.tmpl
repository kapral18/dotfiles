#!/usr/bin/env bash

set -euo pipefail

{{- if eq .isWork true }}
# claude code mcp desired hash (work): {{ include "dot_claude/mcp.work.json" | sha256sum }}
{{- else }}
# claude code mcp desired hash (non-work): {{ include "dot_claude/mcp.personal.json" | sha256sum }}
{{- end }}

source_dir="${CHEZMOI_SOURCE_DIR:-{{ .chezmoi.sourceDir }}}"
# shellcheck source=../../../scripts/chezmoi_lib.sh
source "$source_dir/../scripts/chezmoi_lib.sh"

is_work="{{ if eq .isWork true }}true{{ else }}false{{ end }}"
src="$(chezmoi_pick_src "$is_work" "$source_dir" "dot_claude/mcp.work.json" "dot_claude/mcp.personal.json")"

python3 "$source_dir/../scripts/merge_claude_mcp.py" "$src" "$HOME/.claude.json"
chezmoi_record_checksum "$HOME/.claude.json"
