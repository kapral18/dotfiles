#!/usr/bin/env bash

set -euo pipefail

# copilot settings hash: {{ include "dot_copilot/settings.json" | sha256sum }}
# copilot hooks hash: {{ include "dot_copilot/hooks.json" | sha256sum }}
# mcp_servers hash: {{ include ".chezmoidata/mcp_servers.yaml" | sha256sum }}
# generate_mcp_configs.py hash: {{ include "../scripts/generate_mcp_configs.py" | sha256sum }}
# mcp_registry.py hash: {{ include "../scripts/mcp_registry.py" | sha256sum }}

source_dir="${CHEZMOI_SOURCE_DIR:-{{ .chezmoi.sourceDir }}}"
# shellcheck source=../../../scripts/chezmoi_lib.sh
source "$source_dir/../scripts/chezmoi_lib.sh"

is_work="{{ if eq .isWork true }}true{{ else }}false{{ end }}"
yaml_src="$source_dir/.chezmoidata/mcp_servers.yaml"
gen="$source_dir/../scripts/generate_mcp_configs.py"

# User-level MCP servers (~/.copilot/mcp-config.json): OAuth HTTP servers use
# oauthClientId + auth.redirectPort; stdio servers use type "local". The
# built-in github-mcp-server is provided by Copilot and is not emitted here.
mcp_json="$(python3 "$gen" "$yaml_src" "$is_work" copilot)"
chezmoi_write_if_changed "$mcp_json" "$HOME/.copilot/mcp-config.json"

# User settings (~/.copilot/settings.json) — Copilot owns this file and
# rewrites it at runtime (via /settings, /model, and config.json migration),
# mixing interactive state (chosen model, allowedUrls) with our baseline. Merge
# our declared keys ON TOP of whatever is live so they win without clobbering
# the user's runtime choices; chezmoi ignores the live target.
settings_target="$HOME/.copilot/settings.json"
settings_src="$source_dir/dot_copilot/settings.json"
if [ -f "$settings_target" ]; then
  desired_settings="$(jq -s '.[0] * .[1]' "$settings_target" "$settings_src")"
else
  desired_settings="$(cat "$settings_src")"
fi
chezmoi_write_if_changed "$desired_settings" "$settings_target"

# User-level hooks (~/.copilot/hooks/agent-memory.json): session context,
# worklog, git/PR gates, and the RTK rewrite. PascalCase event names yield the
# VS Code-compatible snake_case payloads our hook scripts read.
chezmoi_write_if_changed "$(cat "$source_dir/dot_copilot/hooks.json")" "$HOME/.copilot/hooks/agent-memory.json"
