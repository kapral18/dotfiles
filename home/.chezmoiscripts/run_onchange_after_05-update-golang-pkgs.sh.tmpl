#!/usr/bin/env bash

set -euo pipefail

if command -v mise >/dev/null 2>&1; then
  export PATH="$HOME/.local/share/mise/shims${PATH:+:${PATH}}"
fi

# Track runtime manager config changes
# {{ include "dot_config/mise/config.toml.tmpl" | sha256sum }}

# This script installs go packages from the default-golang-pkgs file
# {{ include "readonly_dot_default-golang-pkgs.tmpl" | sha256sum }}
# Reconcile helper (re-trigger this hook when it changes):
# {{ include "../scripts/reconcile_golang_pkgs.py" | sha256sum }}

golang_pkgs_template={{ joinPath .chezmoi.sourceDir "readonly_dot_default-golang-pkgs.tmpl" | quote }}

if [[ ! -f "$golang_pkgs_template" ]]; then
  echo "Error: default-golang-pkgs template not found at $golang_pkgs_template"
  exit 1
fi

# Render template into a temp file
golang_pkgs_file="$(mktemp)"
trap 'rm -f "$golang_pkgs_file"' EXIT
if ! chezmoi execute-template <"$golang_pkgs_template" >"$golang_pkgs_file"; then
  echo "Error: Failed to render default-golang-pkgs template"
  exit 1
fi

# Read the file content into an array (bash 3 compatible)
lines=()
while IFS= read -r line || [[ -n "$line" ]]; do
  lines+=("$line")
done <"$golang_pkgs_file"

# Resolve the directory `go install` drops binaries into. `go list -m all` does
# NOT enumerate installed binaries, so the old skip/cleanup logic was a no-op;
# we key off the binary file in GOBIN instead.
gobin_dir="$(go env GOBIN 2>/dev/null || true)"
if [[ -z "$gobin_dir" ]]; then
  gobin_dir="$(go env GOPATH 2>/dev/null || echo "$HOME/go")/bin"
fi

# Derive the binary name `go install` produces for a module path: last path
# segment, skipping a trailing major-version segment (/v2, /v10) and @version.
go_pkg_binary_name() {
  local path=${1%%@*}
  path=${path%/}
  local last=${path##*/}
  local rest=${path%/*}
  local prev=${rest##*/}
  if [[ ${#last} -ge 2 && $last == v* && ${last#v} =~ ^[0-9]+$ && "$rest" != "$path" ]]; then
    last=$prev
  fi
  printf '%s' "$last"
}

# A package is already installed if its binary exists in GOBIN.
is_go_pkg_installed() {
  local pkg=$1 name
  name="$(go_pkg_binary_name "$pkg")"
  [[ -n "$name" && -e "$gobin_dir/$name" ]]
}

# install Go package.
#
# ex: install_go_pkg pkg_name
install_go_pkg() {
  local pkg=$1

  if is_go_pkg_installed "$pkg"; then
    echo "Go package $pkg is already installed, skipping"
    return 0
  fi

  echo "Installing Go package: $pkg"
  if ! go install "$pkg@latest" &>/dev/null; then
    echo "Error: Failed to install Go package $pkg@latest"
    if ! go install "$pkg@master" &>/dev/null; then
      echo "Error: Failed to install Go package $pkg@master"
      if ! go install "$pkg@main" &>/dev/null; then
        echo "Error: Failed to install Go package $pkg@main"
        return 1
      fi
    fi
  fi
  return 0
}

# Install every desired package (skip already-present binaries).
for line in "${lines[@]}"; do
  # Skip empty lines and comments
  [[ -z "$line" || "$line" =~ ^\s*# ]] && continue
  install_go_pkg "$line"
done

# Reconcile: remove binaries this tooling installed previously that are no
# longer in the desired list. A state ledger ensures we only ever remove
# binaries we installed, never hand-installed binaries in GOBIN. Non-trivial
# set/path logic lives in the colocated Python helper (per AGENTS.md).
echo ""
echo "Cleaning up unused Go packages..."
reconcile_helper={{ joinPath .chezmoi.sourceDir "../scripts/reconcile_golang_pkgs.py" | quote }}
state_file="$HOME/.cache/chezmoi/golang-pkgs-state"
if [[ -f "$reconcile_helper" ]]; then
  python3 "$reconcile_helper" "$golang_pkgs_file" "$gobin_dir" "$state_file" || true
else
  echo "Warning: reconcile helper not found at $reconcile_helper; skipping cleanup"
fi

# make new binaries available in the current shell
if command -v mise >/dev/null 2>&1; then
  mise reshim
fi

echo "All Go packages installed successfully"
