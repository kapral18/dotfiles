#!/usr/bin/env bash

set -euo pipefail

if command -v mise >/dev/null 2>&1; then
  export PATH="$HOME/.local/share/mise/shims${PATH:+:${PATH}}"
fi

# Track runtime manager config changes
# {{ include "dot_config/mise/config.toml.tmpl" | sha256sum }}

# This script installs Ruby gems from the default-gems file
# {{ include "readonly_dot_default-gems" | sha256sum }}

gems_file={{ joinPath .chezmoi.sourceDir "readonly_dot_default-gems" | quote }}

if [[ ! -f "$gems_file" ]]; then
  echo "Error: default-gems file not found at $gems_file"
  exit 1
fi

# Read the file content into an array (bash 3 compatible)
lines=()
while IFS= read -r line || [[ -n "$line" ]]; do
  lines+=("$line")
done <"$gems_file"

# install Ruby gem.
#
# ex: install_gem gem_name
install_gem() {
  local gem=$1

  # Check if gem is already installed
  if gem list --local | grep -q "^${gem} "; then
    echo "Gem $gem is already installed, skipping"
    return 0
  fi

  echo "Installing gem: $gem"
  if ! gem install "$gem"; then
    echo "Error: Failed to install gem $gem"
    echo "Retrying with sudo..."
    if ! sudo gem install "$gem"; then
      echo "Error: Failed to install gem $gem even with sudo"
      return 1
    fi
  fi
  return 0
}

for line in "${lines[@]}"; do
  # Skip empty lines and comments
  [[ -z "$line" || "$line" =~ ^\s*# ]] && continue

  install_gem "$line"
done

# make new binaries available in the current shell
if command -v mise >/dev/null 2>&1; then
  mise reshim
fi

echo "All Ruby gems installed successfully"
