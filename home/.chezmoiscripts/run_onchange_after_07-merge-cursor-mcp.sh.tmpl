#!/usr/bin/env bash

set -euo pipefail

{{- if eq .isWork true }}
# cursor mcp desired hash (work): {{ include "dot_cursor/mcp.work.json" | sha256sum }}
{{- else }}
# cursor mcp desired hash (non-work): {{ include "dot_cursor/mcp.personal.json" | sha256sum }}
{{- end }}

source_dir="${CHEZMOI_SOURCE_DIR:-{{ .chezmoi.sourceDir }}}"
# shellcheck source=../../../scripts/chezmoi_lib.sh
source "$source_dir/../scripts/chezmoi_lib.sh"

is_work="{{ if eq .isWork true }}true{{ else }}false{{ end }}"
src="$(chezmoi_pick_src "$is_work" "$source_dir" "dot_cursor/mcp.work.json" "dot_cursor/mcp.personal.json")"

chezmoi_write_if_changed "$(cat "$src")" "$HOME/.cursor/mcp.json"
