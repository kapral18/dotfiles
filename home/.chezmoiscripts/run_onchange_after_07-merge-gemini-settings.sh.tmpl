#!/usr/bin/env bash

set -euo pipefail

# gemini settings hash: {{ include "dot_gemini/settings.json" | sha256sum }}
# mcp_servers hash: {{ include ".chezmoidata/mcp_servers.yaml" | sha256sum }}
# generate_mcp_configs.py hash: {{ include "../scripts/generate_mcp_configs.py" | sha256sum }}
# mcp_registry.py hash: {{ include "../scripts/mcp_registry.py" | sha256sum }}

source_dir="${CHEZMOI_SOURCE_DIR:-{{ .chezmoi.sourceDir }}}"
# shellcheck source=../../../scripts/chezmoi_lib.sh
source "$source_dir/../scripts/chezmoi_lib.sh"

is_work="{{ if eq .isWork true }}true{{ else }}false{{ end }}"
yaml_src="$source_dir/.chezmoidata/mcp_servers.yaml"
gen="$source_dir/../scripts/generate_mcp_configs.py"

mcp_json="$(python3 "$gen" "$yaml_src" "$is_work" gemini)"

desired="$(jq -s '.[0] * .[1]' \
  "$source_dir/dot_gemini/settings.json" \
  <(echo "$mcp_json"))"

chezmoi_write_if_changed "$desired" "$HOME/.gemini/settings.json"
