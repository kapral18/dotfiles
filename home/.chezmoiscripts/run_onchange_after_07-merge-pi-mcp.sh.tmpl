#!/usr/bin/env bash

set -euo pipefail

{{- if eq .isWork true }}
# pi mcp desired hash (work): {{ include "dot_pi/agent/readonly_mcp.work.json" | sha256sum }}
{{- else }}
# pi mcp desired hash (non-work): {{ include "dot_pi/agent/readonly_mcp.personal.json" | sha256sum }}
{{- end }}

source_dir="${CHEZMOI_SOURCE_DIR:-{{ .chezmoi.sourceDir }}}"
# shellcheck source=../../../scripts/chezmoi_lib.sh
source "$source_dir/../scripts/chezmoi_lib.sh"

is_work="{{ if eq .isWork true }}true{{ else }}false{{ end }}"
src="$(chezmoi_pick_src "$is_work" "$source_dir" \
  "dot_pi/agent/readonly_mcp.work.json" \
  "dot_pi/agent/readonly_mcp.personal.json")"

chezmoi_install_if_changed "$src" "$HOME/.pi/agent/mcp.json" 0444
