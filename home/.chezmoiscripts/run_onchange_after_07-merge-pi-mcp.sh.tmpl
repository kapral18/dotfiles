#!/usr/bin/env bash

set -euo pipefail

{{- if eq .isWork true }}
# pi mcp desired hash (work): {{ include "dot_pi/agent/mcp.work.json" | sha256sum }}
{{- else }}
# pi mcp desired hash (non-work): {{ include "dot_pi/agent/mcp.personal.json" | sha256sum }}
{{- end }}

source_dir="${CHEZMOI_SOURCE_DIR:-{{ .chezmoi.sourceDir }}}"
target="$HOME/.pi/agent/mcp.json"
is_work="{{ if eq .isWork true }}true{{ else }}false{{ end }}"

if [ "$is_work" = "true" ]; then
  src="$source_dir/dot_pi/agent/mcp.work.json"
else
  src="$source_dir/dot_pi/agent/mcp.personal.json"
fi

mkdir -p "$(dirname "$target")"

if [ -f "$target" ] && cmp -s "$src" "$target"; then
  exit 0
fi

install -m 0444 "$src" "$target"
