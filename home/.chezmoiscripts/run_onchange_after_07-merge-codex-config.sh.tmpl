#!/usr/bin/env bash

set -euo pipefail

{{- if eq .isWork true }}
# codex config desired hash (work): {{ include "dot_codex/private_config.work.toml" | sha256sum }}
{{- else }}
# codex config desired hash (non-work): {{ include "dot_codex/private_config.personal.toml" | sha256sum }}
{{- end }}

source_dir="${CHEZMOI_SOURCE_DIR:-{{ .chezmoi.sourceDir }}}"
target="$HOME/.codex/config.toml"
is_work="{{ if eq .isWork true }}true{{ else }}false{{ end }}"

mkdir -p "$(dirname "$target")"

if [ "$is_work" = "true" ]; then
  src="$source_dir/dot_codex/private_config.work.toml"

  if ! command -v pass >/dev/null 2>&1; then
    echo "pass is required to render Codex work config" >&2
    exit 1
  fi

  litellm_api_base="$(pass show litellm/api/base | tr -d '\n')"
  if [ -z "$litellm_api_base" ]; then
    echo "Missing pass entry: litellm/api/base" >&2
    exit 1
  fi

  litellm_api_base="${litellm_api_base%/}"
  case "$litellm_api_base" in
  */v1) ;;
  *) litellm_api_base="$litellm_api_base/v1" ;;
  esac

  tmp="$(mktemp)"
  trap 'rm -f "$tmp"' EXIT

  sed \
    -e "s|__LITELLM_API_BASE__|$litellm_api_base|g" \
    -e "s|__CODEX_HOME__|$HOME/.codex|g" \
    "$src" >"$tmp"

  install -m 0600 "$tmp" "$target"
else
  src="$source_dir/dot_codex/private_config.personal.toml"
  install -m 0600 "$src" "$target"
fi
