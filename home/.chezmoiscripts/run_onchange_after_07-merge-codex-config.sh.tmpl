#!/usr/bin/env bash

set -euo pipefail

{{- if eq .isWork true }}
# codex config desired hash (work): {{ include "dot_codex/private_config.work.toml" | sha256sum }}
{{- else }}
# codex config desired hash (non-work): {{ include "dot_codex/private_config.personal.toml" | sha256sum }}
{{- end }}
# mcp_servers hash: {{ include ".chezmoidata/mcp_servers.yaml" | sha256sum }}
# inject_mcp_into_codex_toml.py hash: {{ include "../scripts/inject_mcp_into_codex_toml.py" | sha256sum }}
# mcp_registry.py hash: {{ include "../scripts/mcp_registry.py" | sha256sum }}
# yaml_parser.py hash: {{ include "../scripts/yaml_parser.py" | sha256sum }}
# chezmoi_lib.sh hash: {{ include "../scripts/chezmoi_lib.sh" | sha256sum }}
# managed_config_manifest.py hash: {{ include "../scripts/managed_config_manifest.py" | sha256sum }}
# generated_artifact_ledger.py hash: {{ include "../scripts/generated_artifact_ledger.py" | sha256sum }}

source_dir="${CHEZMOI_SOURCE_DIR:-{{ .chezmoi.sourceDir }}}"
# shellcheck source=../../../scripts/chezmoi_lib.sh
source "$source_dir/../scripts/chezmoi_lib.sh"

is_work="{{ if eq .isWork true }}true{{ else }}false{{ end }}"
profile="{{ if eq .isWork true }}work{{ else }}personal{{ end }}"
target="$HOME/.codex/config.toml"
src="$(chezmoi_pick_src "$is_work" "$source_dir" \
  "dot_codex/private_config.work.toml" \
  "dot_codex/private_config.personal.toml")"

yaml_src="$source_dir/.chezmoidata/mcp_servers.yaml"
inject="$source_dir/../scripts/inject_mcp_into_codex_toml.py"

desired="$(python3 "$inject" "$src" "$yaml_src" "$is_work" codex "$target")"
chezmoi_write_if_changed "$desired" "$target" 0600
chezmoi_record_artifact --id codex-config \
  --producer 07-merge-codex-config --profile "$profile" \
  --target "$target" --ownership-adapter toml-line-excludes \
  --exclude-section '^projects\.' \
  --exclude-section '^tui\.model_availability_nux$' \
  --exclude-section '^hooks\.state\.' \
  --exclude-section '^mcp_servers\..*\.tools(\.|$)' \
  --exclude-key '^mcp_servers\.[^.]+$::^default_tools_approval_mode$' \
  --input "$src" \
  --input "$yaml_src" \
  --transform "$inject" \
  --transform "$source_dir/../scripts/mcp_registry.py" \
  --transform "$source_dir/../scripts/yaml_parser.py" \
  --transform "$source_dir/../scripts/chezmoi_lib.sh" \
  --consumer codex
