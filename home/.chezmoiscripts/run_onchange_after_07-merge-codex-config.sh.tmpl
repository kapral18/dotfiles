#!/usr/bin/env bash

set -euo pipefail

{{- if eq .isWork true }}
# codex config desired hash (work): {{ include "dot_codex/private_config.work.toml" | sha256sum }}
{{- else }}
# codex config desired hash (non-work): {{ include "dot_codex/private_config.personal.toml" | sha256sum }}
{{- end }}

source_dir="${CHEZMOI_SOURCE_DIR:-{{ .chezmoi.sourceDir }}}"
# shellcheck source=../../../scripts/chezmoi_lib.sh
source "$source_dir/../scripts/chezmoi_lib.sh"

is_work="{{ if eq .isWork true }}true{{ else }}false{{ end }}"
target="$HOME/.codex/config.toml"
src="$(chezmoi_pick_src "$is_work" "$source_dir" \
  "dot_codex/private_config.work.toml" \
  "dot_codex/private_config.personal.toml")"

chezmoi_install_if_changed "$src" "$target" 0600
