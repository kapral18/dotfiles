#!/usr/bin/env bash

set -euo pipefail

# Bump when manifest or helper change so chezmoi re-runs the sync.
# manifest hash: {{ include "readonly_dot_default-omlx-models.tmpl" | sha256sum }}
# helper hash:   {{ output "sh" "-c" (printf "shasum -a 256 %q | cut -d' ' -f1" (joinPath .chezmoi.sourceDir "../scripts/sync_omlx_models.py")) | trim }}

{{/* Default to disabled when .downloadOmlxModels is missing, e.g. before
chezmoi init has been re-run after this variable was introduced. */ -}}
{{- $download := false -}}
{{- if hasKey . "downloadOmlxModels" -}}{{- $download = .downloadOmlxModels -}}{{- end -}}
{{ if ne $download true -}}
echo "oMLX model sync is disabled (downloadOmlxModels=false); skipping."
exit 0
{{ end -}}

{{ if ne .chezmoi.os "darwin" -}}
echo "oMLX model sync: non-macOS host; skipping."
exit 0
{{ end -}}

MANIFEST_TEMPLATE={{ joinPath .chezmoi.sourceDir "readonly_dot_default-omlx-models.tmpl" | quote }}
HELPER_SCRIPT={{ joinPath .chezmoi.sourceDir "../scripts/sync_omlx_models.py" | quote }}
MODELS_ROOT="${OMLX_MODELS_ROOT:-$HOME/.omlx/models}"

if [[ ! -f "$MANIFEST_TEMPLATE" ]]; then
  echo "Error: oMLX model manifest not found at $MANIFEST_TEMPLATE" >&2
  exit 1
fi

if [[ ! -f "$HELPER_SCRIPT" ]]; then
  echo "Error: oMLX sync helper not found at $HELPER_SCRIPT" >&2
  exit 1
fi

if ! command -v chezmoi >/dev/null 2>&1; then
  echo "Error: chezmoi CLI not available" >&2
  exit 1
fi

if ! command -v hf >/dev/null 2>&1; then
  echo "Error: hf CLI not installed (expected via Brewfile: brew \"hf\")" >&2
  exit 1
fi

mkdir -p "$MODELS_ROOT"

chezmoi execute-template <"$MANIFEST_TEMPLATE" |
  python3 "$HELPER_SCRIPT" "$MODELS_ROOT"
