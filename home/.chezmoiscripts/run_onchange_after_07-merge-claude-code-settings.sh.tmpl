#!/usr/bin/env bash

set -euo pipefail

{{- if eq .isWork true }}
# claude code settings desired hash (work): {{ include "dot_claude/settings.work.json" | sha256sum }}
{{- else }}
# claude code settings desired hash (non-work): {{ include "dot_claude/settings.personal.json" | sha256sum }}
{{- end }}

source_dir="${CHEZMOI_SOURCE_DIR:-{{ .chezmoi.sourceDir }}}"
target="$HOME/.claude/settings.json"
is_work="{{ if eq .isWork true }}true{{ else }}false{{ end }}"

mkdir -p "$(dirname "$target")"

if [ "$is_work" = "true" ]; then
  src="$source_dir/dot_claude/settings.work.json"
else
  src="$source_dir/dot_claude/settings.personal.json"
fi

install -m 0644 "$src" "$target"
