#!/usr/bin/env bash

set -euo pipefail

{{- if eq .isWork true }}
# pi settings desired hash (work): {{ include "dot_pi/agent/readonly_settings.work.json" | sha256sum }}
# litellm models hash: {{ include ".chezmoidata/litellm_models.yaml" | sha256sum }}
{{- else }}
# pi settings desired hash (non-work): {{ include "dot_pi/agent/readonly_settings.personal.json" | sha256sum }}
# pi models desired hash (non-work): {{ include "dot_pi/agent/readonly_models.personal.json" | sha256sum }}
{{- end }}

source_dir="${CHEZMOI_SOURCE_DIR:-{{ .chezmoi.sourceDir }}}"
target_dir="$HOME/.pi/agent"
is_work="{{ if eq .isWork true }}true{{ else }}false{{ end }}"

install_readonly_if_changed() {
  local src="$1"
  local target="$2"

  mkdir -p "$(dirname "$target")"

  if [ -f "$target" ] && cmp -s "$src" "$target"; then
    return 0
  fi

  install -m 0444 "$src" "$target"
}

if [ "$is_work" = "true" ]; then
  src_settings="$source_dir/dot_pi/agent/readonly_settings.work.json"
  models_yaml="$source_dir/.chezmoidata/litellm_models.yaml"

  if ! command -v pass >/dev/null 2>&1; then
    echo "pass is required to render Pi work LiteLLM config" >&2
    exit 1
  fi

  litellm_api_base="$(pass show litellm/api/base | tr -d '\n')"
  if [ -z "$litellm_api_base" ]; then
    echo "Missing pass entry: litellm/api/base" >&2
    exit 1
  fi

  litellm_api_base="${litellm_api_base%/}"
  case "$litellm_api_base" in
  */v1) ;;
  *) litellm_api_base="$litellm_api_base/v1" ;;
  esac

  tmp_models="$(mktemp)"
  trap 'rm -f "$tmp_models"' EXIT
  python3 "$source_dir/../scripts/generate_pi_models.py" "$models_yaml" "$litellm_api_base" >"$tmp_models"
else
  src_settings="$source_dir/dot_pi/agent/readonly_settings.personal.json"
  src_models="$source_dir/dot_pi/agent/readonly_models.personal.json"
fi

install_readonly_if_changed "$src_settings" "$target_dir/settings.json"
if [ "$is_work" = "true" ]; then
  install_readonly_if_changed "$tmp_models" "$target_dir/models.json"
else
  install_readonly_if_changed "$src_models" "$target_dir/models.json"
fi
