#!/usr/bin/env bash

set -euo pipefail

{{- if eq .isWork true }}
# pi settings desired hash (work): {{ include "dot_pi/agent/readonly_settings.work.json" | sha256sum }}
# litellm models hash: {{ include ".chezmoidata/litellm_models.yaml" | sha256sum }}
{{- else }}
# pi settings desired hash (non-work): {{ include "dot_pi/agent/readonly_settings.personal.json" | sha256sum }}
# pi models desired hash (non-work): {{ include "dot_pi/agent/readonly_models.personal.json" | sha256sum }}
{{- end }}

source_dir="${CHEZMOI_SOURCE_DIR:-{{ .chezmoi.sourceDir }}}"
# shellcheck source=../../../scripts/chezmoi_lib.sh
source "$source_dir/../scripts/chezmoi_lib.sh"

is_work="{{ if eq .isWork true }}true{{ else }}false{{ end }}"
target_dir="$HOME/.pi/agent"

src_settings="$(chezmoi_pick_src "$is_work" "$source_dir" \
  "dot_pi/agent/readonly_settings.work.json" \
  "dot_pi/agent/readonly_settings.personal.json")"

chezmoi_install_if_changed "$src_settings" "$target_dir/settings.json" 0444

if [ "$is_work" = "true" ]; then
  litellm_api_base="$(chezmoi_get_litellm_api_base)"

  tmp_models="$(mktemp)"
  trap 'rm -f "$tmp_models"' EXIT
  python3 "$source_dir/../scripts/generate_pi_models.py" \
    "$source_dir/.chezmoidata/litellm_models.yaml" \
    "$litellm_api_base" >"$tmp_models"

  chezmoi_install_if_changed "$tmp_models" "$target_dir/models.json" 0444
else
  src_models="$source_dir/dot_pi/agent/readonly_models.personal.json"
  chezmoi_install_if_changed "$src_models" "$target_dir/models.json" 0444
fi
