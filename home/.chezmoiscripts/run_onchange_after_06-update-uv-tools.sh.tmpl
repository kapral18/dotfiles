#!/usr/bin/env bash

set -euo pipefail

# This script installs uv tools from the default-uv-tools file

# {{ include "readonly_dot_python-version" | sha256sum }}
# {{ include "readonly_dot_default-uv-tools.tmpl" | sha256sum }}

uv_tools_template={{ joinPath .chezmoi.sourceDir "readonly_dot_default-uv-tools.tmpl" | quote }}

echo "Updating uv global tools..."

if [[ ! -f "$uv_tools_template" ]]; then
  echo "Error: default-uv-tools template not found at $uv_tools_template"
  exit 1
fi

# Render template into an array
rendered_tools="$(mktemp)"
trap 'rm -f "$rendered_tools"' EXIT
if ! chezmoi execute-template <"$uv_tools_template" >"$rendered_tools"; then
  echo "Error: Failed to render default-uv-tools template"
  exit 1
fi
declare -a lines
while IFS= read -r line; do
  lines+=("$line")
done <"$rendered_tools"

install_uv_tool() {
  local tool=$1
  local force="${2:-false}"

  echo "Installing uv tool: $tool"
  local -a install_args=()
  if [[ "$force" == "true" ]]; then
    install_args+=(--force)
  fi
  if ! uv tool install "${install_args[@]}" "$tool" &>/dev/null; then
    echo "Error: Failed to install uv tool $tool"
    return 1
  fi
  return 0
}

uv_tool_key() {
  local spec=$1
  local key="$spec"
  key="${key%%\[*}"
  key="${key%%==*}"
  key="${key%%>=*}"
  key="${key%%<=*}"
  key="${key%%~=*}"
  key="${key%%>*}"
  key="${key%%<*}"
  key="${key%%!*}"
  if [[ "$key" == git+* ]]; then
    key="${key##*/}"
    key="${key%.git}"
  fi
  echo "$key" | xargs
}

contains_item() {
  local needle=$1
  shift || true
  local item
  for item in "$@"; do
    [[ "$item" == "$needle" ]] && return 0
  done
  return 1
}

uv_spec_requires_reapply() {
  local spec=$1
  local key
  key="$(uv_tool_key "$spec")"
  [[ "$spec" != "$key" ]]
}

# Parse tools from rendered template FIRST
declare -a tools_to_install
declare -a tool_keys_to_keep

for line in "${lines[@]}"; do
  # Skip empty lines and comments
  [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue

  # Extract package spec (everything before # or end of line)
  tool_spec=$(echo "$line" | sed 's/[[:space:]]*#.*$//' | xargs)
  if [[ -n "$tool_spec" ]]; then
    tools_to_install+=("$tool_spec")
    tool_keys_to_keep+=("$(uv_tool_key "$tool_spec")")
  fi
done

# Check if we have any tools to install
if [[ ${#tools_to_install[@]} -eq 0 ]]; then
  echo "No tools found in rendered uv tools template to install"
  exit 0
fi

# Clean up unwanted tools (installed but not in our list)
if uv tool list >/dev/null 2>&1; then
  installed_tools=$(uv tool list | grep -v '^-' | awk '{print $1}' || true)
  if [[ -n "$installed_tools" ]]; then
    echo "$installed_tools" | while read -r tool; do
      # Check if this tool is NOT in our desired list
      if ! contains_item "$tool" "${tool_keys_to_keep[@]}"; then
        echo "Uninstalling unwanted uv tool: $tool"
        uv tool uninstall "$tool" &>/dev/null || echo "Warning: Failed to uninstall $tool"
      fi
    done
  fi
fi

# Get currently installed tools (after cleanup)
installed_tools=$(uv tool list | grep -v '^-' | awk '{print $1}' || true)

# Install missing tools
for tool in "${tools_to_install[@]}"; do
  tool_key=$(uv_tool_key "$tool")

  # Check if the tool is already installed
  if [[ -n "$installed_tools" ]] && contains_item "$tool_key" $installed_tools; then
    if uv_spec_requires_reapply "$tool"; then
      echo "uv tool $tool_key is installed; reapplying declared spec: $tool"
      install_uv_tool "$tool" true
      continue
    fi
    echo "uv tool $tool_key is already installed"
    continue
  fi

  install_uv_tool "$tool"
done

echo "All uv tools processed successfully"
