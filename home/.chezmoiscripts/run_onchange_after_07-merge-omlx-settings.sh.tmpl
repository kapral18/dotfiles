#!/usr/bin/env bash

set -euo pipefail

# omlx settings desired hash: {{ include "dot_omlx/settings.json" | sha256sum }}
# merge_omlx_settings.py hash: {{ include "../scripts/merge_omlx_settings.py" | sha256sum }}

source_dir="${CHEZMOI_SOURCE_DIR:-{{ .chezmoi.sourceDir }}}"
# shellcheck source=../../../scripts/chezmoi_lib.sh
source "$source_dir/../scripts/chezmoi_lib.sh"

src="$source_dir/dot_omlx/settings.json"
target="$HOME/.omlx/settings.json"

python3 "$source_dir/../scripts/merge_omlx_settings.py" "$src" "$target"
chezmoi_record_checksum "$target"
