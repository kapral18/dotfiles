# ====================================
# FISH Shell Configuration
# ====================================

# Disable the default fish greeting
set fish_greeting

# ------------------------------------
# Environment Variables
# ------------------------------------

## Language Settings
set -x LANG en_US.UTF-8

## Terminal Settings
if not set -q TERM
    set -x TERM xterm-256color
end

## Editor Settings
# Set default editor to Neovim
set -x EDITOR nvim
set -x VISUAL nvim

## Homebrew Settings
# Disable automatic updates during brew install
set -x HOMEBREW_NO_AUTO_UPDATE 1
# Homebrew paths (adjusted based on template variables)
set -x HOMEBREW_PREFIX {{ .homebrewPrefix }}
set -x HOMEBREW_CELLAR {{ .homebrewPrefix }}/Cellar
set -x HOMEBREW_REPOSITORY {{ .homebrewPrefix }}
set -x MANPATH {{ .homebrewPrefix }}/share/man $MANPATH
set -x INFOPATH {{ .homebrewPrefix }}/share/info $INFOPATH

## SSH Agent (1Password)
set -x SSH_AUTH_SOCK "$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

## Go Path
set -x GOPATH $HOME/go

## Bun Installation Path
set -x BUN_INSTALL "$HOME/.bun"

## GPG TTY Configuration (for amd64 architecture)
{{ if eq .chezmoi.arch "amd64" }}
set -x GPG_TTY (tty)
{{ end -}}

## BAT Theme
set -x BAT_THEME "Catppuccin-mocha"

## Ollama Settings
set -x OLLAMA_NUM_PARALLEL 10
set -x OLLAMA_MAX_QUEUE 2048

# ------------------------------------
# XDG Base Directory Specification
# ------------------------------------

## System Directories
set -x XDG_DATA_DIRS /usr/share /usr/local/share
set -x XDG_CONFIG_DIRS /etc/xdg

## User Directories
set -x XDG_CONFIG_HOME $HOME/.config
set -x XDG_CACHE_HOME $HOME/.cache
set -x XDG_DATA_HOME $HOME/.local/share
set -x XDG_DESKTOP_DIR $HOME/Desktop
set -x XDG_DOCUMENTS_DIR $HOME/Documents
set -x XDG_DOWNLOAD_DIR $HOME/Downloads
set -x XDG_MUSIC_DIR $HOME/Music
set -x XDG_PICTURES_DIR $HOME/Pictures
set -x XDG_VIDEOS_DIR $HOME/Videos

# ------------------------------------
# Path Management
# ------------------------------------

## Function to Prepend Paths if Missing
function prepend_to_path_if_missing --description 'Prepend a path to $PATH if it is not already in $PATH'
    set -l path $argv[1]
    if not contains $path $PATH
        set -x PATH $path $PATH
    end
end

## Prepend Custom Paths
prepend_to_path_if_missing {{ .homebrewPrefix }}/bin
prepend_to_path_if_missing {{ .homebrewPrefix }}/sbin
prepend_to_path_if_missing $HOME/.rbenv/shims
prepend_to_path_if_missing $GOPATH/bin
prepend_to_path_if_missing $HOME/.cargo/bin
prepend_to_path_if_missing $HOME/.local/share/yarn/global/node_modules/.bin/
prepend_to_path_if_missing $HOME/.local/bin
prepend_to_path_if_missing $BUN_INSTALL/bin
prepend_to_path_if_missing $HOME/bin

# ------------------------------------
# FZF Configuration
# ------------------------------------

set FD_OPTIONS "--hidden --follow"

set -x FZF_DEFAULT_OPTS "
    --no-mouse
    --height 80%
    --reverse
    --multi
    --info=inline
    --preview='bat {} --color always'
    --preview-window='right:60%:wrap'
    --bind=ctrl-d:half-page-down,ctrl-u:half-page-up,ctrl-b:page-up,ctrl-f:page-down
"

set -x FZF_DEFAULT_COMMAND "
    git ls-files --cached --others --exclude-standard 2>/dev/null
    || fd --type f --type l $FD_OPTIONS
"

set -x FZF_CTRL_T_COMMAND "$FZF_DEFAULT_COMMAND"
set -x FZF_ALT_C_COMMAND "fd --type d $FD_OPTIONS"

# ------------------------------------
# OpenAI API Key Configuration
# ------------------------------------

if type -q pass; and test -z "$OPENAI_API_KEY"
    set -x OPENAI_API_KEY (pass show openai/api/token)
end

# ------------------------------------
# Conditional Configurations
# ------------------------------------

{{ if ne .isWork true -}}
# Password Store Selection
function wpass --description "Point PASSWORD_STORE_DIR to work"
    set -x PASSWORD_STORE_DIR {{ joinPath .chezmoi.homeDir ".password-store-work" }}
end

function ppass --description "Point PASSWORD_STORE_DIR to personal"
    set -x PASSWORD_STORE_DIR {{ joinPath .chezmoi.homeDir ".password-store" }}
end
{{- end }}

# ------------------------------------
# Interactive Session Configurations
# ------------------------------------

if status --is-interactive

    ## Aliases
    alias b="chatblade -so"
    alias c=chezmoi
    alias fzfi='git ls-files --cached --others --exclude-standard 2>/dev/null || fd --type f --type l $FD_OPTIONS'
    alias g=git
    alias t=tmux
    alias tree='tree -I ".git|node_modules"'
    alias v=nvim

    # LS Aliases with lsd support
    if hash lsd 2>/dev/null
        alias ls='lsd -A'
        alias l='lsd -lAh'
        alias ll='lsd -lAtrh'
        alias la='lsd -A'
    else
        alias ls='ls -A'
        alias l='ls -lAh'
        alias ll='ls -lAtrh'
        alias la='ls -A'
    end

    # GPG Agent Reload Alias
    alias reload_gpg='pkill -9 gpg-agent'

    ## Initializations
    if type -q starship
        starship init fish | source
    end

    if type -q zoxide
        zoxide init fish | source
    end

    if type -q navi
        navi widget fish | source
    end

end

# ------------------------------------
# Tool-Specific Configurations
# ------------------------------------

## RBENV Configuration
# Hardcoded to avoid shell path issues
set -x RBENV_SHELL fish
command rbenv rehash 2>/dev/null

function rbenv
    set command $argv[1]
    set -e argv[1]

    switch "$command"
        case rehash shell
            rbenv "sh-$command" $argv | source
        case '*'
            command rbenv "$command" $argv
    end
end

## Conda Initialization
# >>> conda initialize >>>
# !! Contents within this block are managed by 'conda init' !!
if test -f {{ .homebrewPrefix }}/Caskroom/miniconda/base/bin/conda
    eval {{ .homebrewPrefix }}/Caskroom/miniconda/base/bin/conda "shell.fish" hook $argv | source
else if test -f "{{ .homebrewPrefix }}/Caskroom/miniconda/base/etc/fish/conf.d/conda.fish"
    . "{{ .homebrewPrefix }}/Caskroom/miniconda/base/etc/fish/conf.d/conda.fish"
else
    set -x PATH {{ .homebrewPrefix }}/Caskroom/miniconda/base/bin $PATH
end
# <<< conda initialize <<<

## NVM (Node Version Manager) Configuration
