version = 1

[*]
ctx-size = 262144
n-predict = 262144
n-gpu-layers = all
flash-attn = on
jinja = true
cache-type-k = q8_0
cache-type-v = q8_0
reasoning = auto

[local]
model = {{ .chezmoi.homeDir }}/.llama.cpp/models/Qwen3.6-35B-A3B-UD-Q4_K_XL.gguf
load-on-startup = false

[local-max]
model = {{ .chezmoi.homeDir }}/.llama.cpp/models/Qwen3.6-35B-A3B-abliterated.Q4_K_M.gguf
# The abliterated GGUF ships the stock Qwen template that raises
# "System message must be at the beginning" for Anthropic/Codex-style message
# ordering. Override it with the robust Unsloth template used by `local`.
chat-template-file = {{ .chezmoi.homeDir }}/.config/llama.cpp/qwen3.6-chat-template.jinja
load-on-startup = false
