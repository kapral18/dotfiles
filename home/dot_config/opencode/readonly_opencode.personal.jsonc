{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "openrouter/z-ai/glm-5.1",
  "theme": "catppuccin",
  "share": "disabled",
  "autoupdate": false,
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow",
    "skill": "allow",
    "external_directory": "allow",
    "doom_loop": "ask",
  },
  "agent": {
    "plan": {
      "disable": true,
    },
    "build": {
      "disable": true,
    },
    "explore": {
      "disable": true,
    },
    "general": {
      "disable": true,
    },
    "main": {
      "description": "Main workflow agent",
      "mode": "primary",
      "model": "openrouter/qwen/qwen3.6-plus",
      "reasoning_effort": "high",
    },
  },
  "default_agent": "main",
  "mcp": "__MCP_SERVERS__",
  "provider": {
    "llama-cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
      },
      "models": {
        "local": {
          "name": "Qwen3.6 35B A3B UD-Q4_K_XL (llama.cpp)",
        },
        "local-max": {
          "name": "Qwen3.6 35B A3B abliterated (llama.cpp)",
        },
      },
    },
  },
}
