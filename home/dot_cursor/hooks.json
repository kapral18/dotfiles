{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "$HOME/.agents/hooks/session_context.py",
        "timeout": 10
      }
    ],
    "preToolUse": [
      {
        "command": "rtk hook cursor",
        "matcher": "Shell"
      }
    ],
    "afterShellExecution": [
      {
        "command": "$HOME/.agents/hooks/worklog_recorder.py",
        "timeout": 10
      }
    ],
    "postToolUse": [
      {
        "command": "$HOME/.agents/hooks/worklog_recorder.py",
        "timeout": 10
      }
    ],
    "postToolUseFailure": [
      {
        "command": "$HOME/.agents/hooks/worklog_recorder.py",
        "timeout": 10
      }
    ],
    "afterFileEdit": [
      {
        "command": "$HOME/.agents/hooks/worklog_recorder.py",
        "timeout": 10
      }
    ],
    "beforeShellExecution": [
      {
        "command": "$HOME/.agents/hooks/gemini-pr-anchor-gate.sh",
        "matcher": "gh\\s+api.*pulls/.*/(reviews|comments)",
        "failClosed": true
      },
      {
        "command": "$HOME/.agents/hooks/gemini-git-gate.sh",
        "matcher": "git\\s+(commit|push)",
        "failClosed": true
      }
    ]
  }
}
