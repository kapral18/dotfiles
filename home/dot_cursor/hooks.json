{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "AI_EMBED_WARM=1 $HOME/.agents/hooks/session_context.py",
        "timeout": 10
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "$HOME/.agents/hooks/perturn_recall.py",
        "timeout": 10
      }
    ],
    "afterShellExecution": [
      {
        "command": "$HOME/.agents/hooks/worklog_dispatcher.sh",
        "timeout": 10
      }
    ],
    "postToolUse": [
      {
        "command": "$HOME/.agents/hooks/worklog_dispatcher.sh",
        "timeout": 10
      }
    ],
    "postToolUseFailure": [
      {
        "command": "$HOME/.agents/hooks/worklog_dispatcher.sh",
        "timeout": 10
      }
    ],
    "afterFileEdit": [
      {
        "command": "$HOME/.agents/hooks/worklog_dispatcher.sh",
        "timeout": 10
      }
    ],
    "beforeShellExecution": [
      {
        "command": "$HOME/.agents/hooks/gemini-git-gate.py",
        "matcher": "\\bgit\\b",
        "failClosed": true
      }
    ]
  }
}
