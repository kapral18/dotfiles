{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "$HOME/.agents/hooks/session_context.py",
        "timeout": 10
      }
    ],
    "afterShellExecution": [
      {
        "command": "$HOME/.agents/hooks/worklog_recorder.py",
        "timeout": 10
      },
      {
        "command": "$HOME/.agents/hooks/evidence_anchor.py",
        "timeout": 10
      }
    ],
    "postToolUse": [
      {
        "command": "$HOME/.agents/hooks/worklog_recorder.py",
        "timeout": 10
      },
      {
        "command": "$HOME/.agents/hooks/evidence_anchor.py",
        "timeout": 10
      }
    ],
    "postToolUseFailure": [
      {
        "command": "$HOME/.agents/hooks/worklog_recorder.py",
        "timeout": 10
      },
      {
        "command": "$HOME/.agents/hooks/evidence_anchor.py",
        "timeout": 10
      }
    ],
    "afterFileEdit": [
      {
        "command": "$HOME/.agents/hooks/worklog_recorder.py",
        "timeout": 10
      }
    ],
    "afterAgentResponse": [
      {
        "command": "$HOME/.agents/hooks/evidence_anchor.py",
        "timeout": 10
      }
    ],
    "afterAgentThought": [
      {
        "command": "$HOME/.agents/hooks/evidence_anchor.py",
        "timeout": 10
      }
    ],
    "stop": [
      {
        "command": "$HOME/.agents/hooks/evidence_anchor.py",
        "timeout": 10,
        "loop_limit": 2
      }
    ]
  }
}
