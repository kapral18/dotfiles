{
  "version": 1,
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "$HOME/.agents/hooks/session_context.py",
        "timeoutSec": 10
      }
    ],
    "PreToolUse": [
      {
        "matcher": "bash",
        "type": "command",
        "command": "$HOME/.copilot/hooks/copilot-pr-anchor-gate.sh",
        "timeoutSec": 10
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "$HOME/.agents/hooks/worklog_recorder.py",
        "timeoutSec": 10
      }
    ]
  }
}
