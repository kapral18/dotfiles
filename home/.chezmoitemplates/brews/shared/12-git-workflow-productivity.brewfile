# Entity-level semantic merge driver for Git using tree-sitter
# https://github.com/Ataraxy-Labs/weave
brew "weave"

tap "ataraxy-labs/tap"
# Entity-level diff, blame, impact analysis, and LLM context for Git
# https://github.com/Ataraxy-Labs/sem
# link: false — exposed through ~/bin/sem so it does not compete with GNU
# parallel's `sem` helper in /opt/homebrew/bin.
brew "ataraxy-labs/tap/sem", link: false

# Blazing fast terminal-ui for git
# https://github.com/extrawurst/gitui
brew "gitui"

# Simple terminal UI for git commands
# https://github.com/jesseduffield/lazygit
brew "lazygit"

# Text interface for Git repositories
# https://jonas.github.io/tig/
brew "tig"

# Git commit --fixup, but automatic
# https://github.com/tummychow/git-absorb
brew "git-absorb"

# Syntax-highlighting pager for git
# https://github.com/dandavison/delta
brew "git-delta"

# Syntax-aware diff tool
# https://difftastic.wilfred.me.uk/
brew "difftastic"
