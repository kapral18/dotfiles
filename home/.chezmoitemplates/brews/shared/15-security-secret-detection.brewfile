# Detect and prevent secrets in git repos
# https://github.com/gitleaks/gitleaks
brew "gitleaks"

# Find credentials all over the place
# https://github.com/trufflesecurity/trufflehog
brew "trufflehog"

# Find if an email, username, phone or domain is in breached databases
# https://github.com/swanandx/lemmeknow
brew "lemmeknow"

# Manage GnuPG keys with an interactive TUI
# https://github.com/orhun/gpg-tui
brew "gpg-tui"
