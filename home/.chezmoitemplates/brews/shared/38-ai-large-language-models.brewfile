# AI code agent
# https://github.com/sst/opencode
brew "opencode"

# Terminal tool to right-size LLM models to your hardware (RAM, CPU, GPU)
# https://github.com/AlexsJones/llmfit
brew "llmfit"

# LLM inference in C/C++ with OpenAI/Anthropic-compatible llama-server
# https://github.com/ggml-org/llama.cpp
# HEAD: stable bottle 9590 ships an out-of-sync gated-delta-net op vs its
# qwen35moe caller, aborting on load of Qwen3.6 (qwen35moe) GGUFs with
# `ggml.c: GGML_ASSERT(state->ne[0] == S_v) failed`. master has op+caller
# consistent. Revert to stable once a fixed bottle (>9590) is published.
brew "llama.cpp", args: ["HEAD"]

# Official Hugging Face CLI (`hf`) — model downloads, auth, repo listing
# https://huggingface.co/docs/huggingface_hub/guides/cli
brew "hf"

# Terminal UI for code review — review AI-generated diffs like a GitHub PR,
# annotate with structured comments, export as LLM-ready markdown
# https://github.com/agavra/tuicr
tap "agavra/tap"
brew "agavra/tap/tuicr"
