# ==============================================================================
# Homebrew packages -- assembled from home/.chezmoitemplates/brews/
# Source layout (explore here, NOT this rendered file):
#   brews/shared/NN-<category>.brewfile   -- installed on every machine
#   brews/personal/NN-<category>.brewfile -- installed when .isWork is false
#   brews/work/NN-<category>.brewfile     -- installed when .isWork is true
# Profile membership is the directory; categories keep their ordinal+slug.
# To add a package: drop a brew/cask line in the matching category file
# (create brews/work/NN-<slug>.brewfile + a work block below for work-only).
# ==============================================================================

# ==============================================================================
# CORE DEPENDENCIES
# System libraries and dependencies required by other packages
# ==============================================================================
{{ includeTemplate "brews/shared/01-core-dependencies.brewfile" . -}}

# ==============================================================================
# CHARMBRACELET ECOSYSTEM
# Beautiful command-line tools from Charm
# ==============================================================================
{{ includeTemplate "brews/shared/02-charmbracelet-ecosystem.brewfile" . -}}

# ==============================================================================
# SHELL ENVIRONMENTS & PROMPTS
# Command-line shells and prompt customization
# ==============================================================================
{{ includeTemplate "brews/shared/03-shell-environments-prompts.brewfile" . -}}

# ==============================================================================
# TERMINAL MULTIPLEXERS & SESSION MANAGEMENT
# Tools for managing multiple terminal sessions
# ==============================================================================
{{ includeTemplate "brews/shared/04-terminal-multiplexers-session-management.brewfile" . -}}

