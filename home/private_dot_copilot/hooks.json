{
  "version": 1,
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "$HOME/.agents/hooks/session_context.py",
        "timeoutSec": 10
      }
    ],
    "PreToolUse": [],
    "PostToolUse": [
      {
        "type": "command",
        "command": "$HOME/.agents/hooks/worklog_recorder.py",
        "timeoutSec": 10
      }
    ]
  }
}
