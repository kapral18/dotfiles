def inject_ambient_theme(content: str) -> str:
    if AMBIENT_THEME_STYLE_ID in content:
        return content
    style = ambient_theme_style()
    if re.search(r"</head\s*>", content, flags=re.I):
        return re.sub(r"</head\s*>", lambda _: style + "</head>", content, count=1, flags=re.I)
    return style + content


def artifact_path(name: str | None) -> Path:
    return artifacts_dir() / sanitize_name(name)


def ensure_session() -> Path:
    sdir = session_dir()
    artifacts_dir().mkdir(parents=True, exist_ok=True)
    feedback_dir().mkdir(parents=True, exist_ok=True)
    meta = context()
    meta["updated_at"] = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())
    (sdir / "meta.json").write_text(json.dumps(meta, indent=2) + "\n", encoding="utf-8")
    return sdir


