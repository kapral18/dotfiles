#!/usr/bin/env bash

set -euo pipefail

yarn_pkgs_file="$HOME/.default-yarn-pkgs"

if [[ ! -f "$yarn_pkgs_file" ]]; then
  echo "Error: default-yarn-pkgs file not found at $yarn_pkgs_file"
  exit 1
fi

# Get desired packages
desired_pkgs=()
while IFS= read -r line || [[ -n "$line" ]]; do
  # Trim leading and trailing whitespace
  line="${line#"${line%%[![:space:]]*}"}"
  line="${line%"${line##*[![:space:]]}"}"

  # Skip empty lines and comments
  [[ -z "$line" || "$line" =~ ^# ]] && continue
  desired_pkgs+=("$line")
done <"$yarn_pkgs_file"

# Get currently installed global packages
yarn_global_dir=$(yarn global dir 2>/dev/null || true)
installed_pkgs=()
if [[ -n "$yarn_global_dir" && -f "$yarn_global_dir/package.json" ]]; then
  mapfile -t installed_pkgs < <(jq -r '.dependencies // {} | keys[]' "$yarn_global_dir/package.json" 2>/dev/null || true)
fi

# install yarn package.
#
# ex: install_yarn_pkg pkg_name
install_yarn_pkg() {
  local pkg=$1

  echo "Installing yarn package: $pkg"
  if ! yarn global add "$pkg@latest" &>/dev/null; then
    echo "Error: Failed to install yarn package $pkg@latest"
    return 1
  fi
  return 0
}

# Install missing packages
for pkg in "${desired_pkgs[@]}"; do
  is_installed=false
  for installed in "${installed_pkgs[@]:-}"; do
    if [[ "$installed" == "$pkg" ]]; then
      is_installed=true
      break
    fi
  done

  if [[ "$is_installed" == "false" ]]; then
    install_yarn_pkg "$pkg"
  else
    echo "yarn package $pkg is already installed"
  fi
done

# Uninstall packages that are not in the desired list
for pkg in "${installed_pkgs[@]:-}"; do
  # Skip if empty (happens when mapfile reads empty output)
  [[ -z "$pkg" ]] && continue

  is_desired=false
  for desired in "${desired_pkgs[@]}"; do
    if [[ "$desired" == "$pkg" ]]; then
      is_desired=true
      break
    fi
  done

  if [[ "$is_desired" == "false" ]]; then
    echo "Uninstalling yarn package: $pkg"
    if ! yarn global remove "$pkg" &>/dev/null; then
      echo "Error: Failed to uninstall yarn package $pkg"
    fi
  fi
done

echo "All yarn packages synced successfully"
