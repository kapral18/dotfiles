#!/usr/bin/env bash
# Description: Run Codex, injecting local oMLX model metadata when needed.

set -euo pipefail

real_codex="${CODEX_REAL_BIN:-/opt/homebrew/bin/codex}"
omlx_catalog="${CODEX_OMLX_MODEL_CATALOG:-$HOME/.codex/omlx-model-catalog.json}"
omlx_model="qwen3.6-35b-a3b-5bit"

if [[ ! -x "$real_codex" ]]; then
  echo "Error: real Codex binary not found at $real_codex." >&2
  exit 127
fi

uses_omlx_model=false
previous_arg=""
for arg in "$@"; do
  if [[ "$previous_arg" == "-m" || "$previous_arg" == "--model" ]]; then
    if [[ "$arg" == "$omlx_model" ]]; then
      uses_omlx_model=true
      break
    fi
  fi

  case "$arg" in
    --model="$omlx_model")
      uses_omlx_model=true
      break
      ;;
  esac

  previous_arg="$arg"
done

if [[ "$uses_omlx_model" == true && -f "$omlx_catalog" ]]; then
  exec "$real_codex" -c "model_catalog_json=\"$omlx_catalog\"" "$@"
fi

exec "$real_codex" "$@"
