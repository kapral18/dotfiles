#!/usr/bin/env bash
# Description: Launch GitHub Copilot CLI through the managed resume-safe wrapper.
#
# MCP auth needs no launch-time work: hosted OAuth servers (slack, scsi-main)
# run as ",mcp-token <server> --bridge" stdio bridges declared in the
# chezmoi-rendered ~/.copilot/mcp-config.json, injecting a fresh bearer per
# request. The Python core also replaces bare --resume with an external session
# selection followed by --session-id=<id>, avoiding Copilot 1.0.73's MCP startup race.

set -euo pipefail

exec python3 "$HOME/lib/,copilot/main.py" "$@"
