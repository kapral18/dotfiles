#!/usr/bin/env bash
# Description: Launch the real GitHub Copilot CLI.
#
# MCP auth needs no launch-time work: hosted OAuth servers (slack, scsi-main)
# run as ",mcp-token <server> --bridge" stdio bridges declared in the
# chezmoi-rendered ~/.copilot/mcp-config.json, injecting a fresh bearer per
# request. This wrapper stays as the stable ,copilot entry point that the
# BYOK wrappers (,copilot-litellm, ,copilot-openrouter, ,copilot-cloudflare)
# exec through.

set -euo pipefail

real_copilot="${COPILOT_REAL_BIN:-/opt/homebrew/bin/copilot}"
if [[ ! -x "$real_copilot" ]]; then
  echo "Error: real copilot CLI not found at $real_copilot." >&2
  exit 127
fi

exec "$real_copilot" "$@"
