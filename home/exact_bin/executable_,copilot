#!/usr/bin/env bash
# Description: Launch Copilot after one locked header-auth MCP preflight batch.

set -euo pipefail

lib="${COPILOT_WRAPPER_LIB:-$HOME/lib/,copilot/main.py}"
if [[ ! -f "$lib" ]]; then
  echo "Error: ,copilot library not found at $lib. Run chezmoi apply --no-tty ~/lib/,copilot/main.py." >&2
  exit 127
fi

exec python3 "$lib" "$@"
