#!/usr/bin/env bash
# Description: Model-level control plane for a running oMLX server (status/load/unload).

set -euo pipefail

OMLX_HOST="${OMLX_HOST:-127.0.0.1}"
OMLX_PORT="${OMLX_PORT:-8000}"
OMLX_API_KEY="${OMLX_API_KEY:-}"
OMLX_MODELS_ROOT="${OMLX_MODELS_ROOT:-$HOME/.omlx/models}"

base_url="http://${OMLX_HOST}:${OMLX_PORT}"

curl_args=(-sS)
if [[ -n "$OMLX_API_KEY" ]]; then
  curl_args+=(-H "Authorization: Bearer ${OMLX_API_KEY}")
fi

show_usage() {
  cat <<'EOF'
Usage: ,omlx <subcommand> [args...]

Model-level control plane for a running oMLX server. Wraps the public HTTP
API (GET /v1/models/status, POST /v1/models/<id>/unload, warmup via
/v1/chat/completions). Daemon lifecycle is NOT handled here — use
`brew services start|stop|restart jundot/omlx/omlx`.

Subcommands:
  status            Show all discovered models with loaded/unloaded state,
                    estimated memory size, and the server memory budget.
  load <id>...      Load one or more models into memory. Triggers a lazy-load
                    via /v1/chat/completions (max_tokens=1) because oMLX's
                    public API has no explicit load endpoint.
  unload [id|--all] Unload model(s). With --all, unload everything loaded.
  help              Show this message.

Options for `unload`:
  -a, --all         Unload every model currently loaded.

Environment:
  OMLX_HOST         Default: 127.0.0.1
  OMLX_PORT         Default: 8000
  OMLX_API_KEY      Sent as `Authorization: Bearer <key>` when set.
  OMLX_MODELS_ROOT  Default: ~/.omlx/models (used for disk-scan in `status`).

Examples:
  ,omlx status
  ,omlx load qwen3.6-abliterated-heretic-4bit
  ,omlx unload qwen3.6-abliterated-heretic-4bit
  ,omlx unload --all
EOF
}

require_jq() {
  command -v jq >/dev/null 2>&1 || {
    echo "Error: jq is required (brew install jq)" >&2
    exit 1
  }
}

fetch_status() {
  curl "${curl_args[@]}" --max-time 15 -f "${base_url}/v1/models/status"
}

# Scan ~/.omlx/models for subdirs with a config.json (same "is a model"
# definition as scripts/sync_omlx_models.py and the omlx fish completion).
# Returns a JSON array of {id, size, type} for ids NOT present in $server_ids
# (newline-separated). This is how we surface models downloaded after the
# server started — oMLX only registers on-disk models during
# engine_pool.discover_models() at startup.
scan_undiscovered_disk_models() {
  local server_ids="$1"
  local records=()
  [[ -d "$OMLX_MODELS_ROOT" ]] || {
    printf '%s' '[]'
    return
  }
  for dir in "$OMLX_MODELS_ROOT"/*/; do
    [[ -f "$dir/config.json" ]] || continue
    local name
    name=$(basename "$dir")
    # Skip ids the server already knows about (discovered at startup).
    if grep -qxF "$name" <<<"$server_ids"; then
      continue
    fi
    local size_bytes type
    size_bytes=$(du -sk "$dir" 2>/dev/null | awk '{print $1 * 1024}')
    type=$(jq -r '.model_type // "unknown"' "$dir/config.json" 2>/dev/null)
    records+=("$(jq -n \
      --arg id "$name" \
      --argjson size "${size_bytes:-0}" \
      --arg type "${type:-unknown}" \
      '{id:$id, size:$size, type:$type}')")
  done
  if [[ ${#records[@]} -eq 0 ]]; then
    printf '%s' '[]'
  else
    printf '%s\n' "${records[@]}" | jq -s '.'
  fi
}

cmd_status() {
  require_jq
  local json
  json=$(fetch_status) || {
    echo "Error: oMLX server not reachable at ${base_url}" >&2
    exit 1
  }

  local server_ids disk_records
  server_ids=$(printf '%s' "$json" | jq -r '.models[]?.id')
  disk_records=$(scan_undiscovered_disk_models "$server_ids")

  local loaded_count discovered_count undiscovered_count total_count current_gb budget
  loaded_count=$(printf '%s' "$json" | jq -r '.loaded_count // 0')
  discovered_count=$(printf '%s' "$json" | jq -r '.model_count // 0')
  undiscovered_count=$(printf '%s' "$disk_records" | jq -r 'length')
  total_count=$((discovered_count + undiscovered_count))
  current_gb=$(printf '%s' "$json" | jq -r '((.current_model_memory // 0) / 1073741824) | floor')
  budget=$(printf '%s' "$json" | jq -r 'if .max_model_memory != null then ((.max_model_memory / 1073741824) | floor | tostring) + " GB" else "disabled" end')

  echo "Server: ${base_url}"
  echo "Loaded: ${loaded_count}/${discovered_count} discovered  |  Total on disk: ${total_count}  |  Memory: ~${current_gb} GB  |  Budget: ${budget}"
  echo ""
  printf '%s' "$json" | jq --argjson disk "$disk_records" -r '
    (.models // [] | map({
      id, loaded, estimated_size, engine_type,
      state: (if .loaded then "loaded" else "on disk" end),
      glyph: (if .loaded then "✓" else "·" end),
      sort_key: (if .loaded then 0 else 1 end)
    }))
    + ($disk | map({
      id, loaded: false, estimated_size: .size, engine_type: .type,
      state: "on disk, not discovered",
      glyph: "?",
      sort_key: 2
    }))
    | sort_by(.sort_key, .id)
    | .[]
    | "  \(.glyph) \(.id)  (\(.state), ~\((.estimated_size / 1073741824) | floor) GB, \(.engine_type))"
  '

  if [[ "$undiscovered_count" -gt 0 ]]; then
    echo ""
    echo "Note: ${undiscovered_count} model(s) on disk but not discovered by the server."
    echo "      Restart the server to pick them up:"
    echo "        brew services restart jundot/omlx/omlx"
  fi
}

load_one() {
  local id="$1"
  echo "Loading ${id} (warmup via /v1/chat/completions, up to 5 min)..."
  local body status payload
  payload=$(printf '{"model":"%s","messages":[{"role":"user","content":"."}],"max_tokens":1,"stream":false}' "$id")
  body=$(curl "${curl_args[@]}" --max-time 300 \
    -o /dev/stdout -w $'\n%{http_code}' \
    -X POST "${base_url}/v1/chat/completions" \
    -H "Content-Type: application/json" \
    -d "$payload") || {
    echo "  -> ${id}: connection failed (server may still be loading it)" >&2
    return 1
  }
  status="${body##*$'\n'}"
  body="${body%$'\n'*}"
  if [[ "$status" == "200" ]]; then
    echo "  -> ${id}: loaded"
  else
    echo "  -> ${id}: HTTP ${status}: ${body}" >&2
    return 1
  fi
}

unload_one() {
  local id="$1"
  local body status
  body=$(curl "${curl_args[@]}" --max-time 60 \
    -o /dev/stdout -w $'\n%{http_code}' \
    -X POST "${base_url}/v1/models/${id}/unload") || {
    echo "  -> ${id}: connection failed" >&2
    return 1
  }
  status="${body##*$'\n'}"
  body="${body%$'\n'*}"
  if [[ "$status" == "200" ]]; then
    echo "  -> ${id}: unloaded"
  else
    echo "  -> ${id}: HTTP ${status}: ${body}" >&2
    return 1
  fi
}

cmd_load() {
  [[ $# -gt 0 ]] || {
    echo "Error: ,omlx load requires at least one model id" >&2
    exit 1
  }
  require_jq
  # Fetch discovery state once so we can give a targeted error for ids the
  # server hasn't discovered yet (warmup would 404 with a less useful message).
  local json server_ids
  json=$(fetch_status) || {
    echo "Error: oMLX server not reachable at ${base_url}" >&2
    exit 1
  }
  server_ids=$(printf '%s' "$json" | jq -r '.models[]?.id')

  local failures=0
  for id in "$@"; do
    if grep -qxF "$id" <<<"$server_ids"; then
      load_one "$id" || failures=$((failures + 1))
    elif [[ -f "$OMLX_MODELS_ROOT/$id/config.json" ]]; then
      {
        echo "Error: ${id}: on disk (${OMLX_MODELS_ROOT}/${id}) but not discovered by the server."
        echo "       Restart the server to pick it up:"
        echo "         brew services restart jundot/omlx/omlx"
      } >&2
      failures=$((failures + 1))
    else
      echo "Error: ${id}: not in the server registry and not found at ${OMLX_MODELS_ROOT}/${id}" >&2
      failures=$((failures + 1))
    fi
  done
  [[ $failures -eq 0 ]] || exit 1
}

cmd_unload() {
  local all=0
  local ids=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
    -a | --all) all=1 ;;
    --)
      shift
      ids+=("$@")
      break
      ;;
    -*)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
    *) ids+=("$1") ;;
    esac
    shift
  done

  if [[ $all -eq 1 ]]; then
    require_jq
    local json loaded
    json=$(fetch_status) || {
      echo "Error: oMLX server not reachable at ${base_url}" >&2
      exit 1
    }
    loaded=$(printf '%s' "$json" | jq -r '.models[] | select(.loaded == true) | .id')
    if [[ -z "$loaded" ]]; then
      echo "No models currently loaded on ${base_url}; nothing to do."
      return
    fi
    local failures=0
    while read -r id; do
      unload_one "$id" || failures=$((failures + 1))
    done <<<"$loaded"
    [[ $failures -eq 0 ]] || exit 1
    return
  fi

  [[ ${#ids[@]} -gt 0 ]] || {
    echo "Error: ,omlx unload requires a model id, or --all" >&2
    exit 1
  }
  local failures=0
  for id in "${ids[@]}"; do
    unload_one "$id" || failures=$((failures + 1))
  done
  [[ $failures -eq 0 ]] || exit 1
}

subcommand="${1:-help}"
[[ $# -gt 0 ]] && shift || true

case "$subcommand" in
status) cmd_status ;;
load) cmd_load "$@" ;;
unload) cmd_unload "$@" ;;
help | -h | --help) show_usage ;;
*)
  echo "Unknown subcommand: $subcommand" >&2
  show_usage >&2
  exit 1
  ;;
esac
