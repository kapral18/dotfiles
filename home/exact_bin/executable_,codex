#!/usr/bin/env bash
# Description: Run Codex with managed MCP bearer-token env and local model metadata.

set -euo pipefail

lib="${CODEX_WRAPPER_LIB:-$HOME/lib/,codex/main.py}"
if [[ ! -f "$lib" ]]; then
  echo "Error: ,codex library not found at $lib. Run chezmoi apply --no-tty ~/lib/,codex/main.py." >&2
  exit 127
fi

exec python3 "$lib" "$@"
