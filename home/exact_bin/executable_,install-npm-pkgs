#!/usr/bin/env bash

set -euo pipefail

npm_pkgs_file="$HOME/.default-npm-pkgs"

if [[ ! -f "$npm_pkgs_file" ]]; then
  echo "Error: default-npm-pkgs file not found at $npm_pkgs_file"
  exit 1
fi

# Read the file content into an array
if ! mapfile -t lines <"$npm_pkgs_file"; then
  echo "Error: Failed to read default-npm-pkgs file"
  exit 1
fi

# Get desired packages
desired_pkgs=()
for line in "${lines[@]}"; do
  # Trim leading and trailing whitespace
  line="${line#"${line%%[![:space:]]*}"}"
  line="${line%"${line##*[![:space:]]}"}"

  # Skip empty lines and comments
  [[ -z "$line" || "$line" =~ ^# ]] && continue
  desired_pkgs+=("$line")
done

# Get currently installed global packages
# Using grep to extract the package name from the parseable output correctly
# awk extracts the last part of the path if it's inside node_modules
installed_pkgs=$(npm ls -g --depth=0 --parseable | awk -F '/node_modules/' '{if (NF>1) print $NF}' || true)

# install npm package.
#
# ex: install_npm_pkg pkg_name
install_npm_pkg() {
  local pkg=$1

  echo "Installing npm package: $pkg"
  if ! npm -g install "$pkg@latest" &>/dev/null; then
    echo "Error: Failed to install npm package $pkg@latest"
    return 1
  fi
  return 0
}

# Install missing packages
for pkg in "${desired_pkgs[@]}"; do
  if ! echo "$installed_pkgs" | grep -Fqx "$pkg"; then
    install_npm_pkg "$pkg"
  else
    echo "npm package $pkg is already installed"
  fi
done

# Uninstall packages that are not in the desired list
for pkg in $installed_pkgs; do
  # Skip essential npm packages
  if [[ "$pkg" == "npm" || "$pkg" == "corepack" ]]; then
    continue
  fi

  # If installed package is not in desired list, uninstall it
  if ! printf "%s\n" "${desired_pkgs[@]}" | grep -Fqx "$pkg"; then
    echo "Uninstalling npm package: $pkg"
    if ! npm -g uninstall "$pkg" &>/dev/null; then
      echo "Error: Failed to uninstall npm package $pkg"
    fi
  fi
done

# make it available in the current shell
asdf reshim nodejs || true

echo "All npm packages synced successfully"
