#!/usr/bin/env bash
# Description: Launch cursor-agent with its MCP OAuth tokens refreshed first.
#
# cursor-agent reads each OAuth MCP server's token from its own per-project cache
# (~/.cursor/projects/*/mcp-auth.json) and can refresh it via the browser flow, but
# only when the user runs `cursor-agent mcp login <server>` by hand. A session
# started against a stale cache silently loses those MCP servers until you notice
# and re-authenticate from inside cursor.
#
# This wrapper closes that gap by validating before launch. Critically short,
# expired, or revoked tokens refresh synchronously, and each server must have a
# usable current-workspace cache; a workspace missing auth is seeded from the
# newest verified cached chain, with cursor's browser login as last resort
# before the session starts. Proactive rotation stays off the launch path
# because cursor-agent can refresh a still-valid token itself. Unlike ,copilot,
# no config re-bake is needed.
#
# Refresh is skipped for admin/introspection subcommands (login, logout, mcp,
# update, help, about, status/whoami, models) and for --help/--version, which do
# not start an agent session and must not trigger a browser login.
#
# If a token cannot be refreshed, fail before launch rather than starting a
# session with dead MCP servers.

set -euo pipefail

# This wrapper is named ,cursor, so it never shadows cursor-agent on PATH.
real_cursor="${CURSOR_AGENT_REAL_BIN:-$(command -v cursor-agent 2>/dev/null || true)}"

if [[ -z "$real_cursor" || ! -x "$real_cursor" ]]; then
  echo "Error: real cursor-agent CLI not found on PATH." >&2
  exit 127
fi

config="$HOME/.cursor/mcp.json"

join_by_comma() {
  local result=""
  local item
  for item in "$@"; do
    if [[ -n "$result" ]]; then
      result+=", "
    fi
    result+="$item"
  done
  echo "$result"
}

print_token_refresh_help() {
  echo ",cursor: run ',mcp-token <server> --login' without --quiet to inspect the OAuth flow." >&2
}

# Admin/introspection subcommands that must not trigger an MCP login browser flow.
should_refresh() {
  local arg
  for arg in "$@"; do
    case "$arg" in
    -h | --help | -v | --version | --list-models) return 1 ;;
    esac
  done
  # First non-flag token is the subcommand; refresh only for agent/prompt runs.
  local skip_next=""
  for arg in "$@"; do
    if [[ -n "$skip_next" ]]; then
      skip_next=""
      continue
    fi
    case "$arg" in
    --api-key | -H | --header | --output-format | --mode | --model)
      # Flags that consume the following token as their value.
      skip_next="1"
      continue
      ;;
    -*) continue ;;
    esac
    case "$arg" in
    install-shell-integration | uninstall-shell-integration | login | logout | mcp | \
      update | help | about | status | whoami | models | worker)
      return 1
      ;;
    esac
    break
  done
  return 0
}

if should_refresh "$@" && command -v python3 >/dev/null 2>&1 && [[ -f "$config" ]]; then
  # Bridge runtime needs the OAuth mint workspace (chezmoi 07-generate-mcp-configs).
  # Without it, ,mcp-token --login cannot drive cursor-agent against OAuth HTTP shapes.
  mint_mcp="${HOME}/.cache/mcp-token/oauth-mint/.cursor/mcp.json"
  if ! [[ -f "$mint_mcp" ]]; then
    if python3 - "$config" <<'PY'; then
import json, sys
try:
    servers = json.load(open(sys.argv[1])).get("mcpServers", {})
except (OSError, ValueError):
    raise SystemExit(1)
for spec in servers.values():
    if not isinstance(spec, dict):
        continue
    args = spec.get("args") if isinstance(spec.get("args"), list) else []
    if spec.get("command") == ",mcp-token" and "--bridge" in args:
        raise SystemExit(0)
raise SystemExit(1)
PY
      echo ",cursor: MCP bridge servers are configured but OAuth mint workspace is missing:" >&2
      echo "  $mint_mcp" >&2
      echo ",cursor: re-run chezmoi apply (hook 07-generate-mcp-configs) then retry." >&2
      exit 1
    fi
  fi

  # Derive oauth / bridge-auth servers from ~/.cursor/mcp.json.
  # Authenticated HTTP servers needing a fresh token = servers carrying either
  # cursor-cli's "oauth" block, Cursor IDE's "auth.CLIENT_ID" shape, or a
  # ,mcp-token --bridge command entry (tokenBridge runtime). Slack may be
  # CLIENT_ID-only or bridge-only; scsi-main historically emitted both oauth
  # shapes and now uses the bridge at runtime with mint-workspace OAuth.
  # Deriving the list from the config keeps this in sync with the registry.
  mapfile -t oauth_servers < <(
    python3 - "$config" <<'PY'
import json
import sys

try:
    with open(sys.argv[1]) as f:
        servers = json.load(f).get("mcpServers", {})
except (OSError, ValueError):
    sys.exit(0)

for name, spec in servers.items():
    if not isinstance(spec, dict):
        continue
    auth = spec.get("auth")
    args = spec.get("args") if isinstance(spec.get("args"), list) else []
    is_bridge = spec.get("command") == ",mcp-token" and "--bridge" in args
    if (
        spec.get("oauth")
        or (isinstance(auth, dict) and auth.get("CLIENT_ID"))
        or is_bridge
    ):
        print(name)
PY
  )

  refresh_failures=()
  for server in "${oauth_servers[@]}"; do
    [[ -z "$server" ]] && continue
    # Cursor can refresh its own still-valid token after launch. Keep proactive
    # rotation off this wrapper's critical path, but retain blocking refresh for
    # critically short, expired, or revoked tokens and verify this workspace has
    # its own usable OAuth cache before launch.
    if ! ",mcp-token" "$server" --login --quiet --no-proactive-rotation >/dev/null 2>&1; then
      refresh_failures+=("$server")
    fi
  done

  if ((${#refresh_failures[@]})); then
    echo ",cursor: could not refresh MCP token(s): $(join_by_comma "${refresh_failures[@]}")." >&2
    print_token_refresh_help
    exit 1
  fi
fi

exec "$real_cursor" "$@"
