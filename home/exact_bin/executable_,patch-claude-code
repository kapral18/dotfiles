#!/usr/bin/env bash

set -euo pipefail

# Patches Claude Code's cli.js to honor CLAUDE_CODE_CONTEXT_WINDOW env var.
#
# Claude Code hardcodes context window to 200000 for non-Anthropic models.
# This patch makes the default read from CLAUDE_CODE_CONTEXT_WINDOW if set,
# allowing third-party models (e.g. Gemini via llm-gateway) to use their
# native context window size.
#
# The patch is idempotent and version-agnostic: it targets the constant
# assignment pattern `=200000,<var>=20000,<var>=32000,<var>=64000` which
# encodes the context-window and related token-limit defaults.

SENTINEL="CLAUDE_CODE_CONTEXT_WINDOW"

cli_js="$(npm root -g)/@anthropic-ai/claude-code/cli.js"

if [[ ! -f "$cli_js" ]]; then
  echo "Error: cli.js not found at $cli_js" >&2
  echo "Is @anthropic-ai/claude-code installed globally via npm?" >&2
  exit 1
fi

if grep -q "$SENTINEL" "$cli_js"; then
  echo "claude-code cli.js is already patched"
  exit 0
fi

# Match: =200000,<word>=20000,<word>=32000,<word>=64000
# Replace the 200000 with an env-var override expression.
# The env var is read once at module load time (before any session starts).
if ! perl -ne 'if (/=200000,\w+=20000,\w+=32000,\w+=64000/) { $f=1; last } END { exit($f ? 0 : 1) }' "$cli_js"; then
  echo "Error: could not find context-window constant pattern in cli.js" >&2
  echo "Claude Code may have changed its internals. Manual inspection needed." >&2
  exit 1
fi

cp "$cli_js" "$cli_js.bak"

perl -pi -e \
  's/=200000,(\w+=20000,\w+=32000,\w+=64000)/=parseInt(process.env.CLAUDE_CODE_CONTEXT_WINDOW)||200000,$1/' \
  "$cli_js"

if grep -q "$SENTINEL" "$cli_js"; then
  rm -f "$cli_js.bak"
  echo "claude-code cli.js patched successfully"
  echo "Set CLAUDE_CODE_CONTEXT_WINDOW=1000000 to use 1M context with third-party models"
else
  mv "$cli_js.bak" "$cli_js"
  echo "Error: patch did not apply correctly, restored backup" >&2
  exit 1
fi
