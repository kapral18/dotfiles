#!/usr/bin/env bash
# Description: Launch Claude Code against the local oMLX server with omlx-scoped overrides.
#
# Why this exists:
#   Cloud Claude (opus[1m]) wants a high autoCompactWindow so multi-turn history
#   isn't compacted prematurely. The local oMLX server caps prompts at
#   sampling.max_context_window (see home/dot_omlx/settings.json). Layering a
#   lower autoCompactWindow globally would clamp cloud sessions too; instead,
#   claude `--settings <file>` loads additional settings on top of the base
#   ~/.claude/settings.json, scoped to this invocation only.
#
# What it does:
#   - Points ANTHROPIC_BASE_URL at the oMLX server (respects OMLX_HOST/PORT).
#   - Forces ANTHROPIC_API_KEY to OMLX_API_KEY (blank by default — oMLX accepts
#     unauthenticated local requests unless auth.api_key_set is true).
#   - Adds --settings ~/.claude/settings.omlx.json so autoCompactWindow=200000
#     triggers Claude Code's auto-compact before oMLX would reject a prompt.
#   - Prepends --model $CLAUDE_OMLX_MODEL (default qwen3.6-35b-a3b-5bit);
#     forwarded args can override it since claude accepts a later --model.
#
# Environment:
#   OMLX_HOST            Default: 127.0.0.1
#   OMLX_PORT            Default: 8000
#   OMLX_API_KEY         Default: empty; sent as ANTHROPIC_API_KEY to claude.
#   CLAUDE_OMLX_MODEL    Default: qwen3.6-35b-a3b-5bit. Set empty to
#                        skip injecting --model (useful if a claude setting or
#                        a user-supplied --model should win cleanly).
#   CLAUDE_OMLX_SETTINGS Default: $HOME/.claude/settings.omlx.json. Point at a
#                        different settings file for alternative profiles.

set -euo pipefail

OMLX_HOST="${OMLX_HOST:-127.0.0.1}"
OMLX_PORT="${OMLX_PORT:-8000}"
OMLX_API_KEY="${OMLX_API_KEY:-}"
CLAUDE_OMLX_MODEL="${CLAUDE_OMLX_MODEL-qwen3.6-35b-a3b-5bit}"
CLAUDE_OMLX_SETTINGS="${CLAUDE_OMLX_SETTINGS:-$HOME/.claude/settings.omlx.json}"

if ! command -v claude >/dev/null 2>&1; then
  echo "Error: claude CLI not found on PATH. Install via the npm pkg list or brew, whichever your setup uses." >&2
  exit 127
fi

if [[ ! -f "$CLAUDE_OMLX_SETTINGS" ]]; then
  echo "Error: omlx-scoped claude settings not found at $CLAUDE_OMLX_SETTINGS." >&2
  echo "       Run 'chezmoi apply' to deploy home/dot_claude/settings.omlx.json." >&2
  exit 1
fi

export ANTHROPIC_BASE_URL="http://${OMLX_HOST}:${OMLX_PORT}"
export ANTHROPIC_API_KEY="$OMLX_API_KEY"

args=(--settings "$CLAUDE_OMLX_SETTINGS")
if [[ -n "$CLAUDE_OMLX_MODEL" ]]; then
  args+=(--model "$CLAUDE_OMLX_MODEL")
fi

exec claude "${args[@]}" "$@"
