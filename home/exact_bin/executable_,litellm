#!/usr/bin/env bash

set -euo pipefail

cmd="${1:-start}"

case "$cmd" in
start)
  if ! command -v litellm >/dev/null 2>&1; then
    echo "LiteLLM is not installed." >&2
    exit 1
  fi

  if ! command -v pass >/dev/null 2>&1; then
    echo "pass is required to start LiteLLM (for secrets)." >&2
    exit 1
  fi

  config_path="$HOME/.config/litellm/config.yaml"
  if [[ ! -f "$config_path" ]]; then
    echo "LiteLLM config not found at $config_path" >&2
    echo "Run: chezmoi apply" >&2
    exit 1
  fi

  pid_file="${TMPDIR:-/tmp}/litellm-4000.pid"

  if [[ -f "$pid_file" ]]; then
    old_pid="$(cat "$pid_file" 2>/dev/null || true)"
    if [[ -n "$old_pid" ]] && ps -p "$old_pid" -o comm= 2>/dev/null | grep -q "^litellm$"; then
      kill "$old_pid" >/dev/null 2>&1 || true
      echo "LiteLLM stopped old instance (pid $old_pid)"
      sleep 1
    fi
    rm -f "$pid_file" >/dev/null 2>&1 || true
  fi

  proxy_key="$(pass show litellm/api/token | tr -d '\n')"
  if [[ -z "$proxy_key" ]]; then
    echo "Missing pass entry: litellm/api/token" >&2
    exit 1
  fi

  api_base="$(pass show litellm/api/base | tr -d '\n')"
  if [[ -z "$api_base" ]]; then
    echo "Missing pass entry: litellm/api/base" >&2
    exit 1
  fi

  # Normalize to .../v1 for OpenAI-compatible routes.
  api_base="${api_base%/}"
  case "$api_base" in
  */v1) ;;
  *) api_base="$api_base/v1" ;;
  esac

  LITELLM_PROXY_KEY="$proxy_key" LITELLM_API_BASE="$api_base" \
    nohup litellm --config "$config_path" --port 4000 >/tmp/litellm.log 2>&1 &

  echo $! >"$pid_file"

  echo "LiteLLM started in the background (logs at /tmp/litellm.log)"
  ;;
stop)
  pid_file="${TMPDIR:-/tmp}/litellm-4000.pid"
  if [[ -f "$pid_file" ]]; then
    pid="$(cat "$pid_file" 2>/dev/null || true)"
    if [[ -n "$pid" ]] && ps -p "$pid" -o comm= 2>/dev/null | grep -q "^litellm$"; then
      kill "$pid"
      echo "LiteLLM stopped (pid $pid)"
    else
      echo "LiteLLM is not running"
    fi
    rm -f "$pid_file" >/dev/null 2>&1 || true
  else
    echo "LiteLLM is not running"
  fi
  ;;
status)
  pid_file="${TMPDIR:-/tmp}/litellm-4000.pid"
  if [[ -f "$pid_file" ]]; then
    pid="$(cat "$pid_file" 2>/dev/null || true)"
    if [[ -n "$pid" ]] && ps -p "$pid" -o comm= 2>/dev/null | grep -q "^litellm$"; then
      echo "LiteLLM is running"
      exit 0
    fi
  fi

  echo "LiteLLM is not running"
  exit 1
  ;;
*)
  echo "Usage: ,litellm {start|stop|status}" >&2
  exit 1
  ;;
esac
